  "quizDownloadQ10A1": "Don't ignore it - verify the source and necessity of the file",
  "@quizDownloadQ10A1": {
    "description": "quizDownloadQ10A1"
  },
  "quizDownloadQ10A2": "Switch to an unprotected browser",
  "@quizDownloadQ10A2": {
    "description": "quizDownloadQ10A2"
  },
  "quizDownloadQ10A3": "Browsers are too cautious - always ignore",
  "@quizDownloadQ10A3": {
    "description": "quizDownloadQ10A3"
  },
  "quizDownloadQ10A4": "Disable protection permanently",
  "@quizDownloadQ10A4": {
    "description": "quizDownloadQ10A4"
  },
  "quizDownloadQ10Explain": "Browsers block based on reputation and signatures. If a file is blocked - it's a serious signal. Verify the source before proceeding.",
  "@quizDownloadQ10Explain": {
    "description": "quizDownloadQ10Explain"
  },
  "quiz2faQ6": "Can two-factor authentication be bypassed?",
  "@quiz2faQ6": {
    "description": "quiz2faQ6"
  },
  "quiz2faQ6A1": "Yes - through real-time phishing or SIM-swap, that's why the 2FA method matters",
  "@quiz2faQ6A1": {
    "description": "quiz2faQ6A1"
  },
  "quiz2faQ6A2": "No, 2FA is absolutely impenetrable",
  "@quiz2faQ6A2": {
    "description": "quiz2faQ6A2"
  },
  "quiz2faQ6A3": "Only intelligence agencies can bypass 2FA",
  "@quiz2faQ6A3": {
    "description": "quiz2faQ6A3"
  },
  "quiz2faQ6A4": "2FA protects against all attacks",
  "@quiz2faQ6A4": {
    "description": "quiz2faQ6A4"
  },
  "quiz2faQ6Explain": "Phishing proxies intercept 2FA codes in real time. SIM-swap redirects SMS. Hardware FIDO2 keys are resistant to these attacks.",
  "@quiz2faQ6Explain": {
    "description": "quiz2faQ6Explain"
  },
  "quiz2faQ7": "What is a hardware security key (YubiKey)?",
  "@quiz2faQ7": {
    "description": "quiz2faQ7"
  },
  "quiz2faQ7A1": "A physical device for authentication, resistant to phishing",
  "@quiz2faQ7A1": {
    "description": "quiz2faQ7A1"
  },
  "quiz2faQ7A2": "A USB drive with passwords",
  "@quiz2faQ7A2": {
    "description": "quiz2faQ7A2"
  },
  "quiz2faQ7A3": "A hard drive encryption key",
  "@quiz2faQ7A3": {
    "description": "quiz2faQ7A3"
  },
  "quiz2faQ7A4": "A key fob for unlocking a car",
  "@quiz2faQ7A4": {
    "description": "quiz2faQ7A4"
  },
  "quiz2faQ7Explain": "A FIDO2 key is cryptographically bound to the domain. Even on a perfect phishing site, the key will refuse to authenticate. Phishing is physically impossible.",
  "@quiz2faQ7Explain": {
    "description": "quiz2faQ7Explain"
  },
  "quiz2faQ8": "Why is it important to enable 2FA on email first?",
  "@quiz2faQ8": {
    "description": "quiz2faQ8"
  },
  "quiz2faQ8A1": "Email is the key to all accounts: passwords are reset through it",
  "@quiz2faQ8A1": {
    "description": "quiz2faQ8A1"
  },
  "quiz2faQ8A2": "Email is the most popular service",
  "@quiz2faQ8A2": {
    "description": "quiz2faQ8A2"
  },
  "quiz2faQ8A3": "You can't send email without 2FA",
  "@quiz2faQ8A3": {
    "description": "quiz2faQ8A3"
  },
  "quiz2faQ8A4": "2FA on email is less important than on social media",
  "@quiz2faQ8A4": {
    "description": "quiz2faQ8A4"
  },
  "quiz2faQ8Explain": "If an attacker gains access to your email, they can reset passwords for all linked accounts. Email is the master key of your digital life. 2FA on email is priority #1.",
  "@quiz2faQ8Explain": {
    "description": "quiz2faQ8Explain"
  },
  "quiz2faQ9": "What are backup codes and where to store them?",
  "@quiz2faQ9": {
    "description": "quiz2faQ9"
  },
  "quiz2faQ9A1": "One-time codes for login when 2FA device is lost - in a password manager or safe",
  "@quiz2faQ9A1": {
    "description": "quiz2faQ9A1"
  },
  "quiz2faQ9A2": "Codes for file recovery",
  "@quiz2faQ9A2": {
    "description": "quiz2faQ9A2"
  },
  "quiz2faQ9A3": "Just remember one code",
  "@quiz2faQ9A3": {
    "description": "quiz2faQ9A3"
  },
  "quiz2faQ9A4": "Backup codes last forever",
  "@quiz2faQ9A4": {
    "description": "quiz2faQ9A4"
  },
  "quiz2faQ9Explain": "The service issues 8-10 one-time codes. Store in a password manager or print them. Without them, losing your phone = losing access.",
  "@quiz2faQ9Explain": {
    "description": "quiz2faQ9Explain"
  },
  "quiz2faQ10": "Should you enable 2FA on all accounts?",
  "@quiz2faQ10": {
    "description": "quiz2faQ10"
  },
  "quiz2faQ10A1": "Yes - especially on email, banking, cloud, and social media",
  "@quiz2faQ10A1": {
    "description": "quiz2faQ10A1"
  },
  "quiz2faQ10A2": "Only on banking accounts",
  "@quiz2faQ10A2": {
    "description": "quiz2faQ10A2"
  },
  "quiz2faQ10A3": "2FA is too inconvenient",
  "@quiz2faQ10A3": {
    "description": "quiz2faQ10A3"
  },
  "quiz2faQ10A4": "One main account is enough",
  "@quiz2faQ10A4": {
    "description": "quiz2faQ10A4"
  },
  "quiz2faQ10Explain": "Hacking an 'unimportant' account is dangerous with reused passwords. 2FA makes hacking exponentially harder. Minimum: email + bank + cloud + social media.",
  "@quiz2faQ10Explain": {
    "description": "quiz2faQ10Explain"
  },
  "quizUsbQ6": "What is a USB Killer?",
  "@quizUsbQ6": {
    "description": "quizUsbQ6"
  },
  "quizUsbQ6A1": "A device that sends an electrical discharge through the USB port, destroying hardware",
  "@quizUsbQ6A1": {
    "description": "quizUsbQ6A1"
  },
  "quizUsbQ6A2": "An antivirus for USB drives",
  "@quizUsbQ6A2": {
    "description": "quizUsbQ6A2"
  },
  "quizUsbQ6A3": "A safe removal program",
  "@quizUsbQ6A3": {
    "description": "quizUsbQ6A3"
  },
  "quizUsbQ6A4": "A virus that erases data from flash drives",
  "@quizUsbQ6A4": {
    "description": "quizUsbQ6A4"
  },
  "quizUsbQ6Explain": "USB Killer charges capacitors and discharges 200+ volts back into the port. Result: a burned motherboard. Don't insert unknown USB devices.",
  "@quizUsbQ6Explain": {
    "description": "quizUsbQ6Explain"
  },
  "quizUsbQ7": "How to protect against autorun of malware from USB?",
  "@quizUsbQ7": {
    "description": "quizUsbQ7"
  },
  "quizUsbQ7A1": "Disable autorun in Windows and check flash drive contents manually",
  "@quizUsbQ7A1": {
    "description": "quizUsbQ7A1"
  },
  "quizUsbQ7A2": "Autorun is safe in modern Windows",
  "@quizUsbQ7A2": {
    "description": "quizUsbQ7A2"
  },
  "quizUsbQ7A3": "Using USB 3.0 is enough",
  "@quizUsbQ7A3": {
    "description": "quizUsbQ7A3"
  },
  "quizUsbQ7A4": "Format every flash drive before use",
  "@quizUsbQ7A4": {
    "description": "quizUsbQ7A4"
  },
  "quizUsbQ7Explain": "AutoRun for USB is disabled by default, but AutoPlay may suggest actions. Settings → Devices → AutoPlay → Off. Scan new USB drives with antivirus.",
  "@quizUsbQ7Explain": {
    "description": "quizUsbQ7Explain"
  },
  "quizUsbQ8": "What is juice jacking (USB charging attack)?",
  "@quizUsbQ8": {
    "description": "quizUsbQ8"
  },
  "quizUsbQ8A1": "Data theft through a public USB charging station disguised as a regular one",
  "@quizUsbQ8A1": {
    "description": "quizUsbQ8A1"
  },
  "quizUsbQ8A2": "Electricity theft through USB",
  "@quizUsbQ8A2": {
    "description": "quizUsbQ8A2"
  },
  "quizUsbQ8A3": "Phone overheating from charging",
  "@quizUsbQ8A3": {
    "description": "quizUsbQ8A3"
  },
  "quizUsbQ8A4": "Using someone else's charger",
  "@quizUsbQ8A4": {
    "description": "quizUsbQ8A4"
  },
  "quizUsbQ8Explain": "USB carries both power and data. A modified station can read data or install malware. Use your own power adapter or a data blocker.",
  "@quizUsbQ8Explain": {
    "description": "quizUsbQ8Explain"
  },
  "quizUsbQ9": "What's a safe way to transfer files instead of USB?",
  "@quizUsbQ9": {
    "description": "quizUsbQ9"
  },
  "quizUsbQ9A1": "Cloud storage or transfer via encrypted channel (Wi-Fi Direct, AirDrop)",
  "@quizUsbQ9A1": {
    "description": "quizUsbQ9A1"
  },
  "quizUsbQ9A2": "Bluetooth - it's always safe",
  "@quizUsbQ9A2": {
    "description": "quizUsbQ9A2"
  },
  "quizUsbQ9A3": "Email without restrictions",
  "@quizUsbQ9A3": {
    "description": "quizUsbQ9A3"
  },
  "quizUsbQ9A4": "There are no safe alternatives",
  "@quizUsbQ9A4": {
    "description": "quizUsbQ9A4"
  },
  "quizUsbQ9Explain": "Cloud services scan files with antivirus. Wi-Fi Direct, AirDrop, Nearby Share are encrypted and don't require physical media.",
  "@quizUsbQ9Explain": {
    "description": "quizUsbQ9Explain"
  },
  "quizUsbQ10": "Why is physical security of USB ports important?",
  "@quizUsbQ10": {
    "description": "quizUsbQ10"
  },
  "quizUsbQ10A1": "An attacker can quickly insert a malicious device while you're away",
  "@quizUsbQ10A1": {
    "description": "quizUsbQ10A1"
  },
  "quizUsbQ10A2": "USB ports wear out",
  "@quizUsbQ10A2": {
    "description": "quizUsbQ10A2"
  },
  "quizUsbQ10A3": "Antivirus will stop everything",
  "@quizUsbQ10A3": {
    "description": "quizUsbQ10A3"
  },
  "quizUsbQ10A4": "Ports need to be covered from dust",
  "@quizUsbQ10A4": {
    "description": "quizUsbQ10A4"
  },
  "quizUsbQ10Explain": "Inserting a BadUSB takes a second. On critical computers, use USB blockers or GPO policies restricting new device connections.",
  "@quizUsbQ10Explain": {
    "description": "quizUsbQ10Explain"
  },
  "quizPrivacyQ6": "What is a digital footprint?",
  "@quizPrivacyQ6": {
    "description": "quizPrivacyQ6"
  },
  "quizPrivacyQ6A1": "The totality of all your internet activity - virtually impossible to fully delete",
  "@quizPrivacyQ6A1": {
    "description": "quizPrivacyQ6A1"
  },
  "quizPrivacyQ6A2": "Traces from downloading files",
  "@quizPrivacyQ6A2": {
    "description": "quizPrivacyQ6A2"
  },
  "quizPrivacyQ6A3": "A fingerprint on the screen",
  "@quizPrivacyQ6A3": {
    "description": "quizPrivacyQ6A3"
  },
  "quizPrivacyQ6A4": "Clearing browser history deletes your digital footprint",
  "@quizPrivacyQ6A4": {
    "description": "quizPrivacyQ6A4"
  },
  "quizPrivacyQ6Explain": "Every post, like, purchase forms a digital footprint. Even deleted posts are saved in caches and web archives. Don't post what you don't want to see public in 10 years.",
  "@quizPrivacyQ6Explain": {
    "description": "quizPrivacyQ6Explain"
  },
  "quizPrivacyQ7": "Why use different emails for different purposes?",
  "@quizPrivacyQ7": {
    "description": "quizPrivacyQ7"
  },
  "quizPrivacyQ7A1": "Compromise of one address won't affect others - account isolation",
  "@quizPrivacyQ7A1": {
    "description": "quizPrivacyQ7A1"
  },
  "quizPrivacyQ7A2": "Email services give discounts for multiple accounts",
  "@quizPrivacyQ7A2": {
    "description": "quizPrivacyQ7A2"
  },
  "quizPrivacyQ7A3": "One address can't receive many emails",
  "@quizPrivacyQ7A3": {
    "description": "quizPrivacyQ7A3"
  },
  "quizPrivacyQ7A4": "This is only needed for work",
  "@quizPrivacyQ7A4": {
    "description": "quizPrivacyQ7A4"
  },
  "quizPrivacyQ7Explain": "Separate email for banking, another for forums. A forum database leak won't reveal your banking email. Aliases (SimpleLogin) let you delete a leaked address.",
  "@quizPrivacyQ7Explain": {
    "description": "quizPrivacyQ7Explain"
  },
  "quizPrivacyQ8": "What is doxxing?",
  "@quizPrivacyQ8": {
    "description": "quizPrivacyQ8"
  },
  "quizPrivacyQ8A1": "Collecting and publishing personal information without consent to intimidate",
  "@quizPrivacyQ8A1": {
    "description": "quizPrivacyQ8A1"
  },
  "quizPrivacyQ8A2": "Protecting documents with a password",
  "@quizPrivacyQ8A2": {
    "description": "quizPrivacyQ8A2"
  },
  "quizPrivacyQ8A3": "Archiving files",
  "@quizPrivacyQ8A3": {
    "description": "quizPrivacyQ8A3"
  },
  "quizPrivacyQ8A4": "An identity verification procedure",
  "@quizPrivacyQ8A4": {
    "description": "quizPrivacyQ8A4"
  },
  "quizPrivacyQ8Explain": "Doxxers collect addresses, phone numbers, photos from open sources. Protection: minimize data on social media, use pseudonyms on forums.",
  "@quizPrivacyQ8Explain": {
    "description": "quizPrivacyQ8Explain"
  },
  "quizPrivacyQ9": "How to reduce browser tracking?",
  "@quizPrivacyQ9": {
    "description": "quizPrivacyQ9"
  },
  "quizPrivacyQ9A1": "Use a tracker blocker (uBlock Origin), clear cookies, enable DNS over HTTPS",
  "@quizPrivacyQ9A1": {
    "description": "quizPrivacyQ9A1"
  },
  "quizPrivacyQ9A2": "Incognito mode is sufficient",
  "@quizPrivacyQ9A2": {
    "description": "quizPrivacyQ9A2"
  },
  "quizPrivacyQ9A3": "Install more privacy extensions",
  "@quizPrivacyQ9A3": {
    "description": "quizPrivacyQ9A3"
  },
  "quizPrivacyQ9A4": "Tracking cannot be prevented",
  "@quizPrivacyQ9A4": {
    "description": "quizPrivacyQ9A4"
  },
  "quizPrivacyQ9Explain": "Incognito does NOT protect against trackers. A combination: uBlock Origin, Firefox with Enhanced Tracking Protection, cookie clearing, DNS over HTTPS.",
  "@quizPrivacyQ9Explain": {
    "description": "quizPrivacyQ9Explain"
  },
  "quizPrivacyQ10": "What is the right to be forgotten?",
  "@quizPrivacyQ10": {
    "description": "quizPrivacyQ10"
  },
  "quizPrivacyQ10A1": "A legal right to demand companies delete your personal data",
  "@quizPrivacyQ10A1": {
    "description": "quizPrivacyQ10A1"
  },
  "quizPrivacyQ10A2": "Automatic data deletion after a year",
  "@quizPrivacyQ10A2": {
    "description": "quizPrivacyQ10A2"
  },
  "quizPrivacyQ10A3": "A ban on saving cookies",
  "@quizPrivacyQ10A3": {
    "description": "quizPrivacyQ10A3"
  },
  "quizPrivacyQ10A4": "The right to forget your password",
  "@quizPrivacyQ10A4": {
    "description": "quizPrivacyQ10A4"
  },
  "quizPrivacyQ10Explain": "GDPR grants the right to request data deletion. Google allows removing links, social media - deleting accounts. Use it for unused accounts.",
  "@quizPrivacyQ10Explain": {
    "description": "quizPrivacyQ10Explain"
  },
  "quizLockQ6": "Why set a BIOS/UEFI password?",
  "@quizLockQ6": {
    "description": "quizLockQ6"
  },
  "quizLockQ6A1": "Prevents booting from external media, bypassing OS protection",
  "@quizLockQ6A1": {
    "description": "quizLockQ6A1"
  },
  "quizLockQ6A2": "BIOS password speeds up booting",
  "@quizLockQ6A2": {
    "description": "quizLockQ6A2"
  },
  "quizLockQ6A3": "Without it, the computer won't turn on",
  "@quizLockQ6A3": {
    "description": "quizLockQ6A3"
  },
  "quizLockQ6A4": "BIOS password replaces Windows password",
  "@quizLockQ6A4": {
    "description": "quizLockQ6A4"
  },
  "quizLockQ6Explain": "Without a BIOS password, you can boot from USB and bypass the Windows password. BIOS password + BitLocker = reliable protection against physical access.",
  "@quizLockQ6Explain": {
    "description": "quizLockQ6Explain"
  },
  "quizLockQ7": "How to protect against shoulder surfing?",
  "@quizLockQ7": {
    "description": "quizLockQ7"
  },
  "quizLockQ7A1": "Use biometrics, a privacy screen, and make sure nobody is watching",
  "@quizLockQ7A1": {
    "description": "quizLockQ7A1"
  },
  "quizLockQ7A2": "Enter the password quickly",
  "@quizLockQ7A2": {
    "description": "quizLockQ7A2"
  },
  "quizLockQ7A3": "This is impossible in modern offices",
  "@quizLockQ7A3": {
    "description": "quizLockQ7A3"
  },
  "quizLockQ7A4": "Use a long password",
  "@quizLockQ7A4": {
    "description": "quizLockQ7A4"
  },
  "quizLockQ7Explain": "A privacy screen (3M Privacy Filter) makes the image visible only from a direct angle. Biometrics eliminates shoulder surfing completely.",
  "@quizLockQ7Explain": {
    "description": "quizLockQ7Explain"
  },
  "quizLockQ8": "What screen auto-lock timeout is recommended?",
  "@quizLockQ8": {
    "description": "quizLockQ8"
  },
  "quizLockQ8A1": "2-5 minutes - enough to not annoy you but protect from access",
  "@quizLockQ8A1": {
    "description": "quizLockQ8A1"
  },
  "quizLockQ8A2": "30 minutes - the standard value",
  "@quizLockQ8A2": {
    "description": "quizLockQ8A2"
  },
  "quizLockQ8A3": "Auto-lock is unrelated to security",
  "@quizLockQ8A3": {
    "description": "quizLockQ8A3"
  },
  "quizLockQ8A4": "1 hour for comfortable work",
  "@quizLockQ8A4": {
    "description": "quizLockQ8A4"
  },
  "quizLockQ8Explain": "In 30 minutes, someone can copy files, install a keylogger, or read email. 5 minutes is a balance between convenience and protection.",
  "@quizLockQ8Explain": {
    "description": "quizLockQ8Explain"
  },
  "quizLockQ9": "What's the danger of disabling the Windows login password?",
  "@quizLockQ9": {
    "description": "quizLockQ9"
  },
  "quizLockQ9A1": "Anyone who turns on the computer gets full access to files and accounts",
  "@quizLockQ9A1": {
    "description": "quizLockQ9A1"
  },
  "quizLockQ9A2": "Windows will run slower",
  "@quizLockQ9A2": {
    "description": "quizLockQ9A2"
  },
  "quizLockQ9A3": "No danger",
  "@quizLockQ9A3": {
    "description": "quizLockQ9A3"
  },
  "quizLockQ9A4": "Vulnerability only to network attacks",
  "@quizLockQ9A4": {
    "description": "quizLockQ9A4"
  },
  "quizLockQ9Explain": "Without a password, the computer is an open book: documents, browser passwords, email. If a laptop is stolen, the thief gains instant access.",
  "@quizLockQ9Explain": {
    "description": "quizLockQ9Explain"
  },
  "quizLockQ10": "Why lock your computer at home?",
  "@quizLockQ10": {
    "description": "quizLockQ10"
  },
  "quizLockQ10A1": "The habit protects you elsewhere, and at home - from guests and burglars",
  "@quizLockQ10A1": {
    "description": "quizLockQ10A1"
  },
  "quizLockQ10A2": "Locking isn't needed at home",
  "@quizLockQ10A2": {
    "description": "quizLockQ10A2"
  },
  "quizLockQ10A3": "Only at work",
  "@quizLockQ10A3": {
    "description": "quizLockQ10A3"
  },
  "quizLockQ10A4": "Viruses can unlock the computer",
  "@quizLockQ10A4": {
    "description": "quizLockQ10A4"
  },
  "quizLockQ10Explain": "Win+L should be a reflex. You have guests, couriers, technicians visiting. A habit developed at home will save you in cafes and offices.",
  "@quizLockQ10Explain": {
    "description": "quizLockQ10Explain"
  },
  "quizExtQ6": "What is a browser extension supply chain attack?",
  "@quizExtQ6": {
    "description": "quizExtQ6"
  },
  "quizExtQ6A1": "A developer sells the extension to an attacker who releases a malicious update",
  "@quizExtQ6A1": {
    "description": "quizExtQ6A1"
  },
  "quizExtQ6A2": "An extension delivered by mail",
  "@quizExtQ6A2": {
    "description": "quizExtQ6A2"
  },
  "quizExtQ6A3": "A conflict between extensions",
  "@quizExtQ6A3": {
    "description": "quizExtQ6A3"
  },
  "quizExtQ6A4": "Installing from a file",
  "@quizExtQ6A4": {
    "description": "quizExtQ6A4"
  },
  "quizExtQ6Explain": "In 2020-2023, dozens of popular extensions were sold and updated with malicious code. Minimize the number of extensions.",
  "@quizExtQ6Explain": {
    "description": "quizExtQ6Explain"
  },
  "quizExtQ7": "How to check permissions of installed extensions?",
  "@quizExtQ7": {
    "description": "quizExtQ7"
  },
  "quizExtQ7A1": "chrome://extensions → Details → view site access and permissions",
  "@quizExtQ7A1": {
    "description": "quizExtQ7A1"
  },
  "quizExtQ7A2": "Permissions can't be viewed after installation",
  "@quizExtQ7A2": {
    "description": "quizExtQ7A2"
  },
  "quizExtQ7A3": "Only through reinstallation",
  "@quizExtQ7A3": {
    "description": "quizExtQ7A3"
  },
  "quizExtQ7A4": "All extensions have the same permissions",
  "@quizExtQ7A4": {
    "description": "quizExtQ7A4"
  },
  "quizExtQ7Explain": "In Chrome: Extensions → Manage → click → Details. If a calculator needs access to all sites - remove it.",
  "@quizExtQ7Explain": {
    "description": "quizExtQ7Explain"
  },
  "quizExtQ8": "Do extensions work in incognito mode?",
  "@quizExtQ8": {
    "description": "quizExtQ8"
  },
  "quizExtQ8A1": "By default no - but you can allow it, which creates a tracking risk",
  "@quizExtQ8A1": {
    "description": "quizExtQ8A1"
  },
  "quizExtQ8A2": "All extensions work in incognito",
  "@quizExtQ8A2": {
    "description": "quizExtQ8A2"
  },
  "quizExtQ8A3": "Extensions are safe in incognito",
  "@quizExtQ8A3": {
    "description": "quizExtQ8A3"
  },
  "quizExtQ8A4": "Incognito disables extensions permanently",
  "@quizExtQ8A4": {
    "description": "quizExtQ8A4"
  },
  "quizExtQ8Explain": "An extension enabled in incognito sees all sites you wanted to hide. Only enable trusted ones (uBlock Origin).",
  "@quizExtQ8Explain": {
    "description": "quizExtQ8Explain"
  },
  "quizExtQ9": "Why restrict an extension to specific sites?",
  "@quizExtQ9": {
    "description": "quizExtQ9"
  },
  "quizExtQ9A1": "Instead of access to all sites, give only to needed ones - principle of least privilege",
  "@quizExtQ9A1": {
    "description": "quizExtQ9A1"
  },
  "quizExtQ9A2": "This speeds up the extension",
  "@quizExtQ9A2": {
    "description": "quizExtQ9A2"
  },
  "quizExtQ9A3": "Restriction is impossible in Chrome",
  "@quizExtQ9A3": {
    "description": "quizExtQ9A3"
  },
  "quizExtQ9A4": "Only for paid extensions",
  "@quizExtQ9A4": {
    "description": "quizExtQ9A4"
  },
  "quizExtQ9Explain": "Right-click the icon → 'On specific sites.' A translator doesn't need access to your Gmail inbox.",
  "@quizExtQ9Explain": {
    "description": "quizExtQ9Explain"
  },
  "quizExtQ10": "How do extensions affect browser fingerprinting?",
  "@quizExtQ10": {
    "description": "quizExtQ10"
  },
  "quizExtQ10A1": "The set of extensions makes the browser more unique and recognizable",
  "@quizExtQ10A1": {
    "description": "quizExtQ10A1"
  },
  "quizExtQ10A2": "Extensions hide the fingerprint",
  "@quizExtQ10A2": {
    "description": "quizExtQ10A2"
  },
  "quizExtQ10A3": "Extensions don't affect privacy",
  "@quizExtQ10A3": {
    "description": "quizExtQ10A3"
  },
  "quizExtQ10A4": "Only ad blockers create a fingerprint",
  "@quizExtQ10A4": {
    "description": "quizExtQ10A4"
  },
  "quizExtQ10Explain": "Sites detect extensions by side effects. Paradox: privacy extensions can make you more identifiable.",
  "@quizExtQ10Explain": {
    "description": "quizExtQ10Explain"
  },
  "quizEncryptQ6": "What is AES-256?",
  "@quizEncryptQ6": {
    "description": "quizEncryptQ6"
  },
  "quizEncryptQ6A1": "An encryption algorithm with a 256-bit key - brute-forcing all combinations would take longer than the age of the Universe",
  "@quizEncryptQ6A1": {
    "description": "quizEncryptQ6A1"
  },
  "quizEncryptQ6A2": "A data compression protocol",
  "@quizEncryptQ6A2": {
    "description": "quizEncryptQ6A2"
  },
  "quizEncryptQ6A3": "An antivirus algorithm",
  "@quizEncryptQ6A3": {
    "description": "quizEncryptQ6A3"
  },
  "quizEncryptQ6A4": "An authentication method",
  "@quizEncryptQ6A4": {
    "description": "quizEncryptQ6A4"
  },
  "quizEncryptQ6Explain": "AES-256 is approved by the NSA for classified documents. 2^256 possible keys exceeds the number of atoms in the Universe.",
  "@quizEncryptQ6Explain": {
    "description": "quizEncryptQ6Explain"
  },
  "quizEncryptQ7": "What's the difference between symmetric and asymmetric encryption?",
  "@quizEncryptQ7": {
    "description": "quizEncryptQ7"
  },
  "quizEncryptQ7A1": "Symmetric - one key, asymmetric - a key pair (public + private)",
  "@quizEncryptQ7A1": {
    "description": "quizEncryptQ7A1"
  },
  "quizEncryptQ7A2": "Symmetric is faster, so it's better",
  "@quizEncryptQ7A2": {
    "description": "quizEncryptQ7A2"
  },
  "quizEncryptQ7A3": "Asymmetric is an outdated method",
  "@quizEncryptQ7A3": {
    "description": "quizEncryptQ7A3"
  },
  "quizEncryptQ7A4": "No difference",
  "@quizEncryptQ7A4": {
    "description": "quizEncryptQ7A4"
  },
  "quizEncryptQ7Explain": "HTTPS uses both: asymmetric for key exchange, then symmetric for data. Asymmetric solves the problem of secure key exchange.",
  "@quizEncryptQ7Explain": {
    "description": "quizEncryptQ7Explain"
  },
  "quizEncryptQ8": "Why is it important to encrypt data in the cloud?",
  "@quizEncryptQ8": {
    "description": "quizEncryptQ8"
  },
  "quizEncryptQ8A1": "The provider can technically access unencrypted files",
  "@quizEncryptQ8A1": {
    "description": "quizEncryptQ8A1"
  },
  "quizEncryptQ8A2": "The cloud automatically encrypts everything",
  "@quizEncryptQ8A2": {
    "description": "quizEncryptQ8A2"
  },
  "quizEncryptQ8A3": "Cloud is safe without encryption",
  "@quizEncryptQ8A3": {
    "description": "quizEncryptQ8A3"
  },
  "quizEncryptQ8A4": "Encryption slows sync by 10x",
  "@quizEncryptQ8A4": {
    "description": "quizEncryptQ8A4"
  },
  "quizEncryptQ8Explain": "Google Drive, Dropbox encrypt data but have access to it. Client-side encryption (Cryptomator) guarantees: only you can read the files.",
  "@quizEncryptQ8Explain": {
    "description": "quizEncryptQ8Explain"
  },
  "quizEncryptQ9": "What to do with the BitLocker recovery key?",
  "@quizEncryptQ9": {
    "description": "quizEncryptQ9"
  },
  "quizEncryptQ9A1": "Save in multiple places: Microsoft account, printout, password manager",
  "@quizEncryptQ9A1": {
    "description": "quizEncryptQ9A1"
  },
  "quizEncryptQ9A2": "Memorize it",
  "@quizEncryptQ9A2": {
    "description": "quizEncryptQ9A2"
  },
  "quizEncryptQ9A3": "The key isn't needed",
  "@quizEncryptQ9A3": {
    "description": "quizEncryptQ9A3"
  },
  "quizEncryptQ9A4": "Email it to yourself",
  "@quizEncryptQ9A4": {
    "description": "quizEncryptQ9A4"
  },
  "quizEncryptQ9Explain": "The BitLocker key is 48 digits. Without it, a TPM failure means data is lost forever. At least 2 copies in different locations.",
  "@quizEncryptQ9Explain": {
    "description": "quizEncryptQ9Explain"
  },
  "quizEncryptQ10": "Can you trust free VPNs?",
  "@quizEncryptQ10": {
    "description": "quizEncryptQ10"
  },
  "quizEncryptQ10A1": "Be cautious - many sell user data or contain adware",
  "@quizEncryptQ10A1": {
    "description": "quizEncryptQ10A1"
  },
  "quizEncryptQ10A2": "Free VPNs are just as safe as paid ones",
  "@quizEncryptQ10A2": {
    "description": "quizEncryptQ10A2"
  },
  "quizEncryptQ10A3": "VPN is unrelated to encryption",
  "@quizEncryptQ10A3": {
    "description": "quizEncryptQ10A3"
  },
  "quizEncryptQ10A4": "Free VPNs are faster than paid ones",
  "@quizEncryptQ10A4": {
    "description": "quizEncryptQ10A4"
  },
  "quizEncryptQ10Explain": "38% of free Android VPNs contain malware, 75% use trackers. Reliable free options are rare - research before trusting.",
  "@quizEncryptQ10Explain": {
    "description": "quizEncryptQ10Explain"
  },
