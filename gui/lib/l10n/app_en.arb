  "quizUpdateQ6": "Why is it important to update not only the OS but also browsers?",
  "@quizUpdateQ6": {
    "description": "quizUpdateQ6"
  },
  "quizUpdateQ6A1": "Browsers are the main attack target - you visit sites and download files through them",
  "@quizUpdateQ6A1": {
    "description": "quizUpdateQ6A1"
  },
  "quizUpdateQ6A2": "Browser updates only add bookmarks",
  "@quizUpdateQ6A2": {
    "description": "quizUpdateQ6A2"
  },
  "quizUpdateQ6A3": "Browsers don't need updates",
  "@quizUpdateQ6A3": {
    "description": "quizUpdateQ6A3"
  },
  "quizUpdateQ6A4": "Updating the browser changes the search engine",
  "@quizUpdateQ6A4": {
    "description": "quizUpdateQ6A4"
  },
  "quizUpdateQ6Explain": "The browser is the most attacked program: it processes JavaScript, renders HTML/CSS, and handles networking. Vulnerabilities in Chrome/Firefox are discovered weekly.",
  "@quizUpdateQ6Explain": {
    "description": "quizUpdateQ6Explain"
  },
  "quizUpdateQ7": "What happens if you postpone a Windows update for a month?",
  "@quizUpdateQ7": {
    "description": "quizUpdateQ7"
  },
  "quizUpdateQ7A1": "The system remains vulnerable to already-patched attacks that are actively exploited",
  "@quizUpdateQ7A1": {
    "description": "quizUpdateQ7A1"
  },
  "quizUpdateQ7A2": "Nothing serious - a month isn't critical",
  "@quizUpdateQ7A2": {
    "description": "quizUpdateQ7A2"
  },
  "quizUpdateQ7A3": "Windows will stop working after a month",
  "@quizUpdateQ7A3": {
    "description": "quizUpdateQ7A3"
  },
  "quizUpdateQ7A4": "Microsoft will block your license",
  "@quizUpdateQ7A4": {
    "description": "quizUpdateQ7A4"
  },
  "quizUpdateQ7Explain": "Attackers study patches and create exploits within days. Every day without an update increases risk. Attacks on known CVEs are the most common infection vector.",
  "@quizUpdateQ7Explain": {
    "description": "quizUpdateQ7Explain"
  },
  "quizUpdateQ8": "What is a supply chain attack?",
  "@quizUpdateQ8": {
    "description": "quizUpdateQ8"
  },
  "quizUpdateQ8A1": "An attacker injects malicious code into a legitimate update from the developer",
  "@quizUpdateQ8A1": {
    "description": "quizUpdateQ8A1"
  },
  "quizUpdateQ8A2": "Delayed delivery of an update by mail",
  "@quizUpdateQ8A2": {
    "description": "quizUpdateQ8A2"
  },
  "quizUpdateQ8A3": "Downloading updates from a slow server",
  "@quizUpdateQ8A3": {
    "description": "quizUpdateQ8A3"
  },
  "quizUpdateQ8A4": "Developer refusing to release updates",
  "@quizUpdateQ8A4": {
    "description": "quizUpdateQ8A4"
  },
  "quizUpdateQ8Explain": "SolarWinds attack (2020): hackers embedded a backdoor in a popular software update. 18,000 organizations installed the infected update. Rare but devastating.",
  "@quizUpdateQ8Explain": {
    "description": "quizUpdateQ8Explain"
  },
  "quizUpdateQ9": "How can you check that all programs on your computer are updated?",
  "@quizUpdateQ9": {
    "description": "quizUpdateQ9"
  },
  "quizUpdateQ9A1": "Use an audit utility (Winget upgrade) or each program's built-in update check",
  "@quizUpdateQ9A1": {
    "description": "quizUpdateQ9A1"
  },
  "quizUpdateQ9A2": "Check the install date in Control Panel",
  "@quizUpdateQ9A2": {
    "description": "quizUpdateQ9A2"
  },
  "quizUpdateQ9A3": "If the program opens - it's updated",
  "@quizUpdateQ9A3": {
    "description": "quizUpdateQ9A3"
  },
  "quizUpdateQ9A4": "Reinstall all programs once a year",
  "@quizUpdateQ9A4": {
    "description": "quizUpdateQ9A4"
  },
  "quizUpdateQ9Explain": "Winget (built into Windows 11) can mass-update all programs with one command. Manual checking is ineffective - automate the process.",
  "@quizUpdateQ9Explain": {
    "description": "quizUpdateQ9Explain"
  },
  "quizUpdateQ10": "What are firmware updates and why are they important?",
  "@quizUpdateQ10": {
    "description": "quizUpdateQ10"
  },
  "quizUpdateQ10A1": "Updates for device embedded software (BIOS, router) - they patch hardware-level vulnerabilities",
  "@quizUpdateQ10A1": {
    "description": "quizUpdateQ10A1"
  },
  "quizUpdateQ10A2": "Updates to the device case design",
  "@quizUpdateQ10A2": {
    "description": "quizUpdateQ10A2"
  },
  "quizUpdateQ10A3": "Installing a new processor",
  "@quizUpdateQ10A3": {
    "description": "quizUpdateQ10A3"
  },
  "quizUpdateQ10A4": "Firmware updates automatically and needs no attention",
  "@quizUpdateQ10A4": {
    "description": "quizUpdateQ10A4"
  },
  "quizUpdateQ10Explain": "A router firmware vulnerability can allow interception of all home traffic. BIOS/UEFI firmware affects security even before the OS loads.",
  "@quizUpdateQ10Explain": {
    "description": "quizUpdateQ10Explain"
  },
  "quizPasswordQ6": "What is a passkey and why is it better than a password?",
  "@quizPasswordQ6": {
    "description": "quizPasswordQ6"
  },
  "quizPasswordQ6A1": "A cryptographic key on the device - impossible to brute-force or steal via phishing",
  "@quizPasswordQ6A1": {
    "description": "quizPasswordQ6A1"
  },
  "quizPasswordQ6A2": "A very long password of 100 characters",
  "@quizPasswordQ6A2": {
    "description": "quizPasswordQ6A2"
  },
  "quizPasswordQ6A3": "A password written on a physical key",
  "@quizPasswordQ6A3": {
    "description": "quizPasswordQ6A3"
  },
  "quizPasswordQ6A4": "A biometric iris scan",
  "@quizPasswordQ6A4": {
    "description": "quizPasswordQ6A4"
  },
  "quizPasswordQ6Explain": "Passkey (FIDO2) is a cryptographic key pair. The private key never leaves the device; the server only stores the public one. Phishing is impossible: the key is bound to the domain.",
  "@quizPasswordQ6Explain": {
    "description": "quizPasswordQ6Explain"
  },
  "quizPasswordQ7": "Why are security questions a weak protection?",
  "@quizPasswordQ7": {
    "description": "quizPasswordQ7"
  },
  "quizPasswordQ7A1": "Answers can often be found on social media or guessed",
  "@quizPasswordQ7A1": {
    "description": "quizPasswordQ7A1"
  },
  "quizPasswordQ7A2": "There are too few questions for reliability",
  "@quizPasswordQ7A2": {
    "description": "quizPasswordQ7A2"
  },
  "quizPasswordQ7A3": "They only work in English",
  "@quizPasswordQ7A3": {
    "description": "quizPasswordQ7A3"
  },
  "quizPasswordQ7A4": "Servers don't encrypt the answers",
  "@quizPasswordQ7A4": {
    "description": "quizPasswordQ7A4"
  },
  "quizPasswordQ7Explain": "Mother's maiden name, pet's name - all on social media. In 2008, Sarah Palin's Yahoo account was hacked via a security question. Use random answers and store them in a password manager.",
  "@quizPasswordQ7Explain": {
    "description": "quizPasswordQ7Explain"
  },
  "quizPasswordQ8": "What is a brute force attack?",
  "@quizPasswordQ8": {
    "description": "quizPasswordQ8"
  },
  "quizPasswordQ8A1": "Automated testing of all password combinations until the correct one is found",
  "@quizPasswordQ8A1": {
    "description": "quizPasswordQ8A1"
  },
  "quizPasswordQ8A2": "Physically destroying a computer to extract data",
  "@quizPasswordQ8A2": {
    "description": "quizPasswordQ8A2"
  },
  "quizPasswordQ8A3": "Using force to obtain a password from the owner",
  "@quizPasswordQ8A3": {
    "description": "quizPasswordQ8A3"
  },
  "quizPasswordQ8A4": "A virus that deletes all passwords from the system",
  "@quizPasswordQ8A4": {
    "description": "quizPasswordQ8A4"
  },
  "quizPasswordQ8Explain": "In brute force, a program tests billions of combinations per second. A 6-character password - seconds; 12+ random characters - thousands of years. Length is the best defense.",
  "@quizPasswordQ8Explain": {
    "description": "quizPasswordQ8Explain"
  },
  "quizPasswordQ9": "How can you check if your password has been leaked?",
  "@quizPasswordQ9": {
    "description": "quizPasswordQ9"
  },
  "quizPasswordQ9A1": "Use Have I Been Pwned - it checks your email against breach databases",
  "@quizPasswordQ9A1": {
    "description": "quizPasswordQ9A1"
  },
  "quizPasswordQ9A2": "Try logging into all accounts",
  "@quizPasswordQ9A2": {
    "description": "quizPasswordQ9A2"
  },
  "quizPasswordQ9A3": "Call your email provider",
  "@quizPasswordQ9A3": {
    "description": "quizPasswordQ9A3"
  },
  "quizPasswordQ9A4": "Password leaks cannot be detected",
  "@quizPasswordQ9A4": {
    "description": "quizPasswordQ9A4"
  },
  "quizPasswordQ9Explain": "Have I Been Pwned contains billions of breached records. Password managers (Bitwarden, 1Password) also warn about leaks automatically.",
  "@quizPasswordQ9Explain": {
    "description": "quizPasswordQ9Explain"
  },
  "quizPasswordQ10": "Why is it dangerous to send passwords through messengers?",
  "@quizPasswordQ10": {
    "description": "quizPasswordQ10"
  },
  "quizPasswordQ10A1": "Messages may be stored on the server or read on a compromised device",
  "@quizPasswordQ10A1": {
    "description": "quizPasswordQ10A1"
  },
  "quizPasswordQ10A2": "Messengers compress text and the password may change",
  "@quizPasswordQ10A2": {
    "description": "quizPasswordQ10A2"
  },
  "quizPasswordQ10A3": "Passwords can't be copied from messengers",
  "@quizPasswordQ10A3": {
    "description": "quizPasswordQ10A3"
  },
  "quizPasswordQ10A4": "It's safe in an encrypted messenger",
  "@quizPasswordQ10A4": {
    "description": "quizPasswordQ10A4"
  },
  "quizPasswordQ10Explain": "Even in an encrypted messenger, the password is visible on the recipient's screen. If their device is compromised - the password is compromised. Use password managers with secure sharing.",
  "@quizPasswordQ10Explain": {
    "description": "quizPasswordQ10Explain"
  },
  "quizWifiQ6": "Is it safe to make online purchases on public Wi-Fi?",
  "@quizWifiQ6": {
    "description": "quizWifiQ6"
  },
  "quizWifiQ6A1": "Better to wait - even with HTTPS, a DNS attack can substitute the site",
  "@quizWifiQ6A1": {
    "description": "quizWifiQ6A1"
  },
  "quizWifiQ6A2": "Yes, HTTPS fully protects transactions",
  "@quizWifiQ6A2": {
    "description": "quizWifiQ6A2"
  },
  "quizWifiQ6A3": "Yes, if the purchase amount is small",
  "@quizWifiQ6A3": {
    "description": "quizWifiQ6A3"
  },
  "quizWifiQ6A4": "Only through Wi-Fi without a password",
  "@quizWifiQ6A4": {
    "description": "quizWifiQ6A4"
  },
  "quizWifiQ6Explain": "HTTPS protects data but not from DNS spoofing or compromised certificates. For financial operations, use mobile data or a VPN.",
  "@quizWifiQ6Explain": {
    "description": "quizWifiQ6Explain"
  },
  "quizWifiQ7": "How do you protect a home Wi-Fi router?",
  "@quizWifiQ7": {
    "description": "quizWifiQ7"
  },
  "quizWifiQ7A1": "Change the factory password, use WPA3, update firmware, disable WPS",
  "@quizWifiQ7A1": {
    "description": "quizWifiQ7A1"
  },
  "quizWifiQ7A2": "A complex Wi-Fi password is sufficient",
  "@quizWifiQ7A2": {
    "description": "quizWifiQ7A2"
  },
  "quizWifiQ7A3": "Hide the router - weak signal = security",
  "@quizWifiQ7A3": {
    "description": "quizWifiQ7A3"
  },
  "quizWifiQ7A4": "Home Wi-Fi doesn't need protection",
  "@quizWifiQ7A4": {
    "description": "quizWifiQ7A4"
  },
  "quizWifiQ7Explain": "Factory router passwords are known from databases. WPS has vulnerabilities. A combination: unique admin password + WPA3 + fresh firmware + WPS disabled.",
  "@quizWifiQ7Explain": {
    "description": "quizWifiQ7Explain"
  },
  "quizWifiQ8": "What is an Evil Twin attack on Wi-Fi?",
  "@quizWifiQ8": {
    "description": "quizWifiQ8"
  },
  "quizWifiQ8A1": "A fake access point with the same name to intercept traffic",
  "@quizWifiQ8A1": {
    "description": "quizWifiQ8A1"
  },
  "quizWifiQ8A2": "Two routers conflicting with each other",
  "@quizWifiQ8A2": {
    "description": "quizWifiQ8A2"
  },
  "quizWifiQ8A3": "A virus that clones a laptop via Wi-Fi",
  "@quizWifiQ8A3": {
    "description": "quizWifiQ8A3"
  },
  "quizWifiQ8A4": "Connecting two devices to one network",
  "@quizWifiQ8A4": {
    "description": "quizWifiQ8A4"
  },
  "quizWifiQ8Explain": "The attacker creates an access point with the name of a real network. Your device connects automatically. All traffic passes through the attacker.",
  "@quizWifiQ8Explain": {
    "description": "quizWifiQ8Explain"
  },
  "quizWifiQ9": "Why doesn't hiding the network name (SSID) protect Wi-Fi?",
  "@quizWifiQ9": {
    "description": "quizWifiQ9"
  },
  "quizWifiQ9A1": "Hidden networks are easily discovered with special tools - it's a security illusion",
  "@quizWifiQ9A1": {
    "description": "quizWifiQ9A1"
  },
  "quizWifiQ9A2": "Hiding SSID is the most reliable protection method",
  "@quizWifiQ9A2": {
    "description": "quizWifiQ9A2"
  },
  "quizWifiQ9A3": "Hidden networks work slower",
  "@quizWifiQ9A3": {
    "description": "quizWifiQ9A3"
  },
  "quizWifiQ9A4": "You can't connect to a hidden network",
  "@quizWifiQ9A4": {
    "description": "quizWifiQ9A4"
  },
  "quizWifiQ9Explain": "Airodump-ng discovers hidden networks in seconds - the name is transmitted in probe requests. Instead of hiding, use WPA3 and up-to-date firmware.",
  "@quizWifiQ9Explain": {
    "description": "quizWifiQ9Explain"
  },
  "quizWifiQ10": "What is MAC filtering and why is it unreliable?",
  "@quizWifiQ10": {
    "description": "quizWifiQ10"
  },
  "quizWifiQ10A1": "Restricting access by MAC address - easily bypassed since MAC can be spoofed",
  "@quizWifiQ10A1": {
    "description": "quizWifiQ10A1"
  },
  "quizWifiQ10A2": "Filtering malicious websites",
  "@quizWifiQ10A2": {
    "description": "quizWifiQ10A2"
  },
  "quizWifiQ10A3": "Blocking Apple devices from connecting",
  "@quizWifiQ10A3": {
    "description": "quizWifiQ10A3"
  },
  "quizWifiQ10A4": "Router antivirus feature",
  "@quizWifiQ10A4": {
    "description": "quizWifiQ10A4"
  },
  "quizWifiQ10Explain": "The MAC address is transmitted in plain text. An attacker intercepts an allowed MAC and clones it in seconds. This is security through obscurity, not real protection.",
  "@quizWifiQ10Explain": {
    "description": "quizWifiQ10Explain"
  },
  "quizPhishingQ6": "What is vishing?",
  "@quizPhishingQ6": {
    "description": "quizPhishingQ6"
  },
  "quizPhishingQ6A1": "Phone phishing - a call from a 'bank' to extract data",
  "@quizPhishingQ6A1": {
    "description": "quizPhishingQ6A1"
  },
  "quizPhishingQ6A2": "Visual phishing through images",
  "@quizPhishingQ6A2": {
    "description": "quizPhishingQ6A2"
  },
  "quizPhishingQ6A3": "Phishing through video calls",
  "@quizPhishingQ6A3": {
    "description": "quizPhishingQ6A3"
  },
  "quizPhishingQ6A4": "Sending viruses through voice messages",
  "@quizPhishingQ6A4": {
    "description": "quizPhishingQ6A4"
  },
  "quizPhishingQ6Explain": "Vishing uses calls with spoofed numbers. The scammer creates urgency: 'Your account is blocked, tell us the SMS code.' Banks never ask for codes over the phone.",
  "@quizPhishingQ6Explain": {
    "description": "quizPhishingQ6Explain"
  },
  "quizPhishingQ7": "What is smishing?",
  "@quizPhishingQ7": {
    "description": "quizPhishingQ7"
  },
  "quizPhishingQ7A1": "Phishing via SMS - a link to a fake site in a text message",
  "@quizPhishingQ7A1": {
    "description": "quizPhishingQ7A1"
  },
  "quizPhishingQ7A2": "Phishing through smartwatches",
  "@quizPhishingQ7A2": {
    "description": "quizPhishingQ7A2"
  },
  "quizPhishingQ7A3": "Sending viruses via Bluetooth",
  "@quizPhishingQ7A3": {
    "description": "quizPhishingQ7A3"
  },
  "quizPhishingQ7A4": "SMS message encryption",
  "@quizPhishingQ7A4": {
    "description": "quizPhishingQ7A4"
  },
  "quizPhishingQ7Explain": "Typical smishing: 'Your package is delayed, follow the link.' The link leads to a fake site. Don't follow links from SMS.",
  "@quizPhishingQ7Explain": {
    "description": "quizPhishingQ7Explain"
  },
  "quizPhishingQ8": "How to recognize a phishing email besides checking the domain?",
  "@quizPhishingQ8": {
    "description": "quizPhishingQ8"
  },
  "quizPhishingQ8A1": "Urgency, threats, errors, impersonal greeting, suspicious attachments",
  "@quizPhishingQ8A1": {
    "description": "quizPhishingQ8A1"
  },
  "quizPhishingQ8A2": "Phishing emails always contain errors",
  "@quizPhishingQ8A2": {
    "description": "quizPhishingQ8A2"
  },
  "quizPhishingQ8A3": "Phishing is only possible through email",
  "@quizPhishingQ8A3": {
    "description": "quizPhishingQ8A3"
  },
  "quizPhishingQ8A4": "Emails from acquaintances are always safe",
  "@quizPhishingQ8A4": {
    "description": "quizPhishingQ8A4"
  },
  "quizPhishingQ8Explain": "Red flags: 'Urgent!', 'Account blocked', impersonal greeting. AI generates convincing texts. Check the sender, links, and request logic.",
  "@quizPhishingQ8Explain": {
    "description": "quizPhishingQ8Explain"
  },
  "quizPhishingQ9": "What is a BEC attack (Business Email Compromise)?",
  "@quizPhishingQ9": {
    "description": "quizPhishingQ9"
  },
  "quizPhishingQ9A1": "A fake email from a manager requesting a money transfer",
  "@quizPhishingQ9A1": {
    "description": "quizPhishingQ9A1"
  },
  "quizPhishingQ9A2": "Hacking email to send spam",
  "@quizPhishingQ9A2": {
    "description": "quizPhishingQ9A2"
  },
  "quizPhishingQ9A3": "Encrypting corporate correspondence",
  "@quizPhishingQ9A3": {
    "description": "quizPhishingQ9A3"
  },
  "quizPhishingQ9A4": "Sorting business emails",
  "@quizPhishingQ9A4": {
    "description": "quizPhishingQ9A4"
  },
  "quizPhishingQ9Explain": "BEC is one of the most expensive attacks (average loss $120,000). The attacker waits for a payment moment and sends an email with changed details. Confirm transfers by phone.",
  "@quizPhishingQ9Explain": {
    "description": "quizPhishingQ9Explain"
  },
  "quizPhishingQ10": "What to do if you accidentally clicked a phishing link?",
  "@quizPhishingQ10": {
    "description": "quizPhishingQ10"
  },
  "quizPhishingQ10A1": "Don't enter data, close the page, change passwords, run antivirus scan",
  "@quizPhishingQ10A1": {
    "description": "quizPhishingQ10A1"
  },
  "quizPhishingQ10A2": "Nothing - the virus is already installed",
  "@quizPhishingQ10A2": {
    "description": "quizPhishingQ10A2"
  },
  "quizPhishingQ10A3": "Restart the computer",
  "@quizPhishingQ10A3": {
    "description": "quizPhishingQ10A3"
  },
  "quizPhishingQ10A4": "Send the scammers a reply email",
  "@quizPhishingQ10A4": {
    "description": "quizPhishingQ10A4"
  },
  "quizPhishingQ10Explain": "The click itself is usually not dangerous - entering data is. If you didn't enter anything - close the page. If you entered a password - change it and enable 2FA.",
  "@quizPhishingQ10Explain": {
    "description": "quizPhishingQ10Explain"
  },
  "quizBackupQ6": "What's the difference between full and incremental backup?",
  "@quizBackupQ6": {
    "description": "quizBackupQ6"
  },
  "quizBackupQ6A1": "Full copies everything, incremental - only changes since the last backup",
  "@quizBackupQ6A1": {
    "description": "quizBackupQ6A1"
  },
  "quizBackupQ6A2": "Full backup is larger but incremental is unreliable",
  "@quizBackupQ6A2": {
    "description": "quizBackupQ6A2"
  },
  "quizBackupQ6A3": "Incremental is the same thing, just faster",
  "@quizBackupQ6A3": {
    "description": "quizBackupQ6A3"
  },
  "quizBackupQ6A4": "Full backup only works on external drives",
  "@quizBackupQ6A4": {
    "description": "quizBackupQ6A4"
  },
  "quizBackupQ6Explain": "Incremental backup saves time and space. Optimal strategy: full backup weekly + daily incrementals.",
  "@quizBackupQ6Explain": {
    "description": "quizBackupQ6Explain"
  },
  "quizBackupQ7": "Why is it important to encrypt backups?",
  "@quizBackupQ7": {
    "description": "quizBackupQ7"
  },
  "quizBackupQ7A1": "An unencrypted backup on a stolen drive gives access to all data",
  "@quizBackupQ7A1": {
    "description": "quizBackupQ7A1"
  },
  "quizBackupQ7A2": "Encryption speeds up recovery",
  "@quizBackupQ7A2": {
    "description": "quizBackupQ7A2"
  },
  "quizBackupQ7A3": "Encryption is required by law",
  "@quizBackupQ7A3": {
    "description": "quizBackupQ7A3"
  },
  "quizBackupQ7A4": "Without encryption, backups corrupt faster",
  "@quizBackupQ7A4": {
    "description": "quizBackupQ7A4"
  },
  "quizBackupQ7Explain": "If an external drive is stolen or a cloud account is hacked - unencrypted backup means full data access. BitLocker or cloud encryption solves this.",
  "@quizBackupQ7Explain": {
    "description": "quizBackupQ7Explain"
  },
  "quizBackupQ8": "What is an air-gapped backup?",
  "@quizBackupQ8": {
    "description": "quizBackupQ8"
  },
  "quizBackupQ8A1": "A backup on media physically disconnected from the network and computer",
  "@quizBackupQ8A1": {
    "description": "quizBackupQ8A1"
  },
  "quizBackupQ8A2": "Backup on an airplane",
  "@quizBackupQ8A2": {
    "description": "quizBackupQ8A2"
  },
  "quizBackupQ8A3": "Wireless backup over Wi-Fi",
  "@quizBackupQ8A3": {
    "description": "quizBackupQ8A3"
  },
  "quizBackupQ8A4": "Cloud backup with VPN",
  "@quizBackupQ8A4": {
    "description": "quizBackupQ8A4"
  },
  "quizBackupQ8Explain": "Air-gapped backup is a drive connected only during copying. Ransomware can't encrypt a disconnected drive. The most reliable ransomware protection.",
  "@quizBackupQ8Explain": {
    "description": "quizBackupQ8Explain"
  },
  "quizBackupQ9": "How often should you make backups?",
  "@quizBackupQ9": {
    "description": "quizBackupQ9"
  },
  "quizBackupQ9A1": "Depends on data value: daily for important, weekly for the rest",
  "@quizBackupQ9A1": {
    "description": "quizBackupQ9A1"
  },
  "quizBackupQ9A2": "Once a year is enough",
  "@quizBackupQ9A2": {
    "description": "quizBackupQ9A2"
  },
  "quizBackupQ9A3": "Only before reinstalling the system",
  "@quizBackupQ9A3": {
    "description": "quizBackupQ9A3"
  },
  "quizBackupQ9A4": "Once when buying the computer",
  "@quizBackupQ9A4": {
    "description": "quizBackupQ9A4"
  },
  "quizBackupQ9Explain": "Think: how much work can you afford to lose? If losing a day is critical - backup daily. Automate: manual backups get forgotten.",
  "@quizBackupQ9Explain": {
    "description": "quizBackupQ9Explain"
  },
  "quizBackupQ10": "What to do if a backup can't be restored?",
  "@quizBackupQ10": {
    "description": "quizBackupQ10"
  },
  "quizBackupQ10A1": "The backup is corrupted - you should have tested restoration beforehand",
  "@quizBackupQ10A1": {
    "description": "quizBackupQ10A1"
  },
  "quizBackupQ10A2": "Try again in a week",
  "@quizBackupQ10A2": {
    "description": "quizBackupQ10A2"
  },
  "quizBackupQ10A3": "Backups always restore successfully",
  "@quizBackupQ10A3": {
    "description": "quizBackupQ10A3"
  },
  "quizBackupQ10A4": "Contact the drive manufacturer's support",
  "@quizBackupQ10A4": {
    "description": "quizBackupQ10A4"
  },
  "quizBackupQ10Explain": "An untested backup is not a backup. Test restoration monthly. Corrupted sectors, outdated formats, forgotten passwords - all discovered only during testing.",
  "@quizBackupQ10Explain": {
    "description": "quizBackupQ10Explain"
  },
