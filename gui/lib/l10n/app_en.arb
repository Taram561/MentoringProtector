    "description": "quizPrivacyQ4A1"
  },
  "quizPrivacyQ4A2": "Social media slows down from too many posts",
  "@quizPrivacyQ4A2": {
    "description": "quizPrivacyQ4A2"
  },
  "quizPrivacyQ4A3": "Friends might get offended by content",
  "@quizPrivacyQ4A3": {
    "description": "quizPrivacyQ4A3"
  },
  "quizPrivacyQ4A4": "Photos take up server space",
