  "threatPreventionTitle": "How to Prevent",
  "@threatPreventionTitle": {
    "description": "threatPreventionTitle"
  },
  "threatRemTrojan": "1. Quarantine or delete the file.\n2. Change passwords if the trojan could have intercepted them.\n3. Check startup programs (Win+R → msconfig → Startup).\n4. Run a full computer scan.",
  "@threatRemTrojan": {
    "description": "threatRemTrojan"
  },
  "threatRemAdware": "1. Uninstall the suspicious program via Settings → Apps.\n2. Reset browser settings.\n3. Check browser extensions and remove unknown ones.\n4. Clear temporary files.",
  "@threatRemAdware": {
    "description": "threatRemAdware"
  },
  "threatRemPup": "1. Uninstall the program via Settings → Apps.\n2. Check if browser settings changed (home page, search engine).\n3. Remove associated browser extensions.",
  "@threatRemPup": {
    "description": "threatRemPup"
  },
  "threatRemWorm": "1. Immediately disconnect the computer from the network.\n2. Delete the file and run a full scan.\n3. Check all connected devices and flash drives.\n4. Change passwords for network accounts.",
  "@threatRemWorm": {
    "description": "threatRemWorm"
  },
  "threatRemRansom": "1. DO NOT pay the ransom - it doesn't guarantee file recovery.\n2. Disconnect the computer from the network.\n3. Check for available backups.\n4. Consult a cybersecurity specialist.",
  "@threatRemRansom": {
    "description": "threatRemRansom"
  },
  "threatRemGeneric": "1. Quarantine the file for safe storage.\n2. Run a full computer scan.\n3. Check the system for other suspicious files.",
  "@threatRemGeneric": {
    "description": "threatRemGeneric"
  },
  "threatVecTrojan": "• Downloading pirated software or cracks\n• Attachments in phishing emails\n• Fake software updates on websites\n• Infected USB drives",
  "@threatVecTrojan": {
    "description": "threatVecTrojan"
  },
  "threatVecAdware": "• Installing free software with bundled components\n• Clicking deceptive ads\n• Downloading from unverified sources",
  "@threatVecAdware": {
    "description": "threatVecAdware"
  },
  "threatVecPup": "• Using 'Express' install instead of 'Custom'\n• Bundles during free software installation\n• Deceptive 'Download' buttons on websites",
  "@threatVecPup": {
    "description": "threatVecPup"
  },
  "threatVecWorm": "• Vulnerabilities in network services\n• Infected files on local network\n• Autorun from USB devices\n• Exploits via unpatched software",
  "@threatVecWorm": {
    "description": "threatVecWorm"
  },
  "threatVecRansom": "• Phishing emails with infected attachments\n• Exploit kits on compromised websites\n• RDP vulnerabilities (remote access)\n• Pirated software with embedded ransomware",
  "@threatVecRansom": {
    "description": "threatVecRansom"
  },
  "threatVecGeneric": "• Downloading files from unverified sources\n• Clicking suspicious links\n• Connecting infected external devices",
  "@threatVecGeneric": {
    "description": "threatVecGeneric"
  },
  "threatPrevTrojan": "• Download software only from official websites\n• Don't open attachments from unknown senders\n• Keep your system and antivirus updated\n• Enable two-factor authentication on important accounts",
  "@threatPrevTrojan": {
    "description": "threatPrevTrojan"
  },
  "threatPrevAdware": "• Always choose 'Custom' installation\n• Don't click suspicious ads and banners\n• Use an ad blocker in your browser",
  "@threatPrevAdware": {
    "description": "threatPrevAdware"
  },
  "threatPrevPup": "• Read installation terms and uncheck additional programs\n• Download software only from official websites\n• Use a package manager (winget, chocolatey)",
  "@threatPrevPup": {
    "description": "threatPrevPup"
  },
  "threatPrevWorm": "• Regularly install security updates\n• Use a firewall and don't disable it\n• Disable USB autorun\n• Don't connect unknown flash drives",
  "@threatPrevWorm": {
    "description": "threatPrevWorm"
  },
  "threatPrevRansom": "• Regularly create backups (3-2-1 rule)\n• Don't open suspicious attachments\n• Disable RDP if not in use\n• Keep OS and software updated",
  "@threatPrevRansom": {
    "description": "threatPrevRansom"
  },
  "threatPrevGeneric": "• Use antivirus with up-to-date databases\n• Don't download files from unverified sources\n• Regularly update your operating system\n• Be cautious with email attachments",
  "@threatPrevGeneric": {
    "description": "threatPrevGeneric"
  },
