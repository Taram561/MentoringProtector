  },
  "quizPhishingQ5": "How can you check if a link is safe before clicking?",
  "@quizPhishingQ5": {
    "description": "quizPhishingQ5"
  },
  "quizPhishingQ5A1": "Hover over it and check the domain in the status bar without clicking",
  "@quizPhishingQ5A1": {
