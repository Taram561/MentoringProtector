  "quizUpdateQ1": "Why is it important to install OS and software updates?",
  "@quizUpdateQ1": {
    "description": "quizUpdateQ1"
  },
  "quizUpdateQ1A1": "They fix security vulnerabilities that attackers exploit",
  "@quizUpdateQ1A1": {
    "description": "quizUpdateQ1A1"
  },
  "quizUpdateQ1A2": "They only add new features",
  "@quizUpdateQ1A2": {
    "description": "quizUpdateQ1A2"
  },
  "quizUpdateQ1A3": "They make the computer faster",
  "@quizUpdateQ1A3": {
    "description": "quizUpdateQ1A3"
  },
  "quizUpdateQ1Explain": "Updates often patch known vulnerabilities (CVE). The WannaCry attack in 2017 exploited a flaw that had a patch available 2 months prior.",
  "@quizUpdateQ1Explain": {
    "description": "quizUpdateQ1Explain"
  },
  "quizUpdateQ2": "What should you do if an update requires a restart?",
  "@quizUpdateQ2": {
    "description": "quizUpdateQ2"
  },
  "quizUpdateQ2A1": "Save your work and restart soon - don't delay for days",
  "@quizUpdateQ2A1": {
    "description": "quizUpdateQ2A1"
  },
  "quizUpdateQ2A2": "Postpone it indefinitely - restarts are annoying",
  "@quizUpdateQ2A2": {
    "description": "quizUpdateQ2A2"
  },
  "quizUpdateQ2A3": "Disable automatic updates entirely",
  "@quizUpdateQ2A3": {
    "description": "quizUpdateQ2A3"
  },
  "quizUpdateQ2Explain": "Delaying restarts leaves your system exposed. Most attacks target known, already-patched vulnerabilities.",
  "@quizUpdateQ2Explain": {
    "description": "quizUpdateQ2Explain"
  },
  "quizPasswordQ1": "Which password is the most secure?",
  "@quizPasswordQ1": {
    "description": "quizPasswordQ1"
  },
  "quizPasswordQ1A1": "A random phrase: 'correct horse battery staple'",
  "@quizPasswordQ1A1": {
    "description": "quizPasswordQ1A1"
  },
  "quizPasswordQ1A2": "Your birth date: '19052000'",
  "@quizPasswordQ1A2": {
    "description": "quizPasswordQ1A2"
  },
  "quizPasswordQ1A3": "A simple modification: 'P@ssword123'",
  "@quizPasswordQ1A3": {
    "description": "quizPasswordQ1A3"
  },
  "quizPasswordQ1Explain": "Random passphrases are long and hard to guess, yet easy to remember. Dictionary substitutions like P@ssword are well-known to attackers.",
  "@quizPasswordQ1Explain": {
    "description": "quizPasswordQ1Explain"
  },
  "quizPasswordQ2": "Why should you use a different password for each service?",
  "@quizPasswordQ2": {
    "description": "quizPasswordQ2"
  },
  "quizPasswordQ2A1": "If one service is breached, attackers can't access your other accounts",
  "@quizPasswordQ2A1": {
    "description": "quizPasswordQ2A1"
  },
  "quizPasswordQ2A2": "It's not really necessary - one strong password is enough",
  "@quizPasswordQ2A2": {
    "description": "quizPasswordQ2A2"
  },
  "quizPasswordQ2A3": "Websites require it",
  "@quizPasswordQ2A3": {
    "description": "quizPasswordQ2A3"
  },
  "quizPasswordQ2Explain": "Credential stuffing attacks test leaked passwords across many services. Unique passwords limit damage to just the breached service.",
  "@quizPasswordQ2Explain": {
    "description": "quizPasswordQ2Explain"
  },
  "quizPhishingQ1": "You receive an email from 'support@paypa1.com' asking to verify your account. What do you do?",
  "@quizPhishingQ1": {
    "description": "quizPhishingQ1"
  },
  "quizPhishingQ1A1": "Don't click - 'paypa1' uses the digit 1 instead of the letter l",
  "@quizPhishingQ1A1": {
    "description": "quizPhishingQ1A1"
  },
  "quizPhishingQ1A2": "Click the link and enter your login",
  "@quizPhishingQ1A2": {
    "description": "quizPhishingQ1A2"
  },
  "quizPhishingQ1A3": "Forward the email to friends",
  "@quizPhishingQ1A3": {
    "description": "quizPhishingQ1A3"
  },
  "quizPhishingQ1Explain": "Homoglyph attacks use similar-looking characters (1 vs l, 0 vs O). Always verify the exact domain spelling before clicking.",
  "@quizPhishingQ1Explain": {
    "description": "quizPhishingQ1Explain"
  },
  "quizPhishingQ2": "Which is the safest way to visit your bank's website?",
  "@quizPhishingQ2": {
    "description": "quizPhishingQ2"
  },
  "quizPhishingQ2A1": "Type the URL manually in the address bar or use a saved bookmark",
  "@quizPhishingQ2A1": {
    "description": "quizPhishingQ2A1"
  },
  "quizPhishingQ2A2": "Search for it in Google and click the first result",
  "@quizPhishingQ2A2": {
    "description": "quizPhishingQ2A2"
  },
  "quizPhishingQ2A3": "Click a link in an email from the bank",
  "@quizPhishingQ2A3": {
    "description": "quizPhishingQ2A3"
  },
  "quizPhishingQ2Explain": "Attackers can buy ads that appear above real search results, and spoofed emails are common. Manual entry or bookmarks are the safest.",
  "@quizPhishingQ2Explain": {
    "description": "quizPhishingQ2Explain"
  },
  "quizPhishingQ3": "A website shows a lock icon (HTTPS). Does this mean it's safe?",
  "@quizPhishingQ3": {
    "description": "quizPhishingQ3"
  },
  "quizPhishingQ3A1": "No - HTTPS only means the connection is encrypted, not that the site is trustworthy",
  "@quizPhishingQ3A1": {
    "description": "quizPhishingQ3A1"
  },
  "quizPhishingQ3A2": "Yes - the lock guarantees the site is legitimate",
  "@quizPhishingQ3A2": {
    "description": "quizPhishingQ3A2"
  },
  "quizPhishingQ3A3": "Only if the lock is green",
  "@quizPhishingQ3A3": {
    "description": "quizPhishingQ3A3"
  },
  "quizPhishingQ3Explain": "Free certificates (Let's Encrypt) mean phishing sites can also have HTTPS. The lock encrypts traffic but doesn't verify the site's intentions.",
  "@quizPhishingQ3Explain": {
    "description": "quizPhishingQ3Explain"
  },
  "quizDownloadQ1": "You need a program. What is the safest source?",
  "@quizDownloadQ1": {
    "description": "quizDownloadQ1"
  },
  "quizDownloadQ1A1": "The official website of the developer or an official app store",
  "@quizDownloadQ1A1": {
    "description": "quizDownloadQ1A1"
  },
  "quizDownloadQ1A2": "A torrent with 'cracked' in the name",
  "@quizDownloadQ1A2": {
    "description": "quizDownloadQ1A2"
  },
  "quizDownloadQ1A3": "A random download site from a search result",
  "@quizDownloadQ1A3": {
    "description": "quizDownloadQ1A3"
  },
  "quizDownloadQ1Explain": "Third-party download sites and cracks often bundle malware. Official sources and stores verify software integrity.",
  "@quizDownloadQ1Explain": {
    "description": "quizDownloadQ1Explain"
  },
  "quizDownloadQ2": "A downloaded file has a double extension 'invoice.pdf.exe'. What does this mean?",
  "@quizDownloadQ2": {
    "description": "quizDownloadQ2"
  },
  "quizDownloadQ2A1": "It is an executable disguised as a PDF - likely malware",
  "@quizDownloadQ2A1": {
    "description": "quizDownloadQ2A1"
  },
  "quizDownloadQ2A2": "It is a normal PDF document",
  "@quizDownloadQ2A2": {
    "description": "quizDownloadQ2A2"
  },
  "quizDownloadQ2A3": "Windows added the extra extension automatically",
  "@quizDownloadQ2A3": {
    "description": "quizDownloadQ2A3"
  },
  "quizDownloadQ2Explain": "Windows hides known extensions by default. Attackers add a fake extension before the real one (.exe) to trick users into opening malware.",
  "@quizDownloadQ2Explain": {
    "description": "quizDownloadQ2Explain"
  },
  "quizWifiQ1": "Why is public Wi-Fi (cafés, airports) dangerous?",
  "@quizWifiQ1": {
    "description": "quizWifiQ1"
  },
  "quizWifiQ1A1": "Attackers on the same network can intercept your unencrypted traffic",
  "@quizWifiQ1A1": {
    "description": "quizWifiQ1A1"
  },
  "quizWifiQ1A2": "It's always slower than mobile data",
  "@quizWifiQ1A2": {
    "description": "quizWifiQ1A2"
  },
  "quizWifiQ1A3": "Public Wi-Fi has no dangers if the site uses HTTPS",
  "@quizWifiQ1A3": {
    "description": "quizWifiQ1A3"
  },
  "quizWifiQ1Explain": "On public networks, attackers can run man-in-the-middle attacks. Use a VPN or avoid entering sensitive data on public Wi-Fi.",
  "@quizWifiQ1Explain": {
    "description": "quizWifiQ1Explain"
  },
  "quiz2faQ1": "What is two-factor authentication (2FA)?",
  "@quiz2faQ1": {
    "description": "quiz2faQ1"
  },
  "quiz2faQ1A1": "An extra verification step (code via SMS/app) in addition to your password",
  "@quiz2faQ1A1": {
    "description": "quiz2faQ1A1"
  },
  "quiz2faQ1A2": "Using two different passwords",
  "@quiz2faQ1A2": {
    "description": "quiz2faQ1A2"
  },
  "quiz2faQ1A3": "Logging in from two devices at once",
  "@quiz2faQ1A3": {
    "description": "quiz2faQ1A3"
  },
  "quiz2faQ1Explain": "2FA requires something you know (password) + something you have (phone/token). Even if your password leaks, the attacker still can't log in without the second factor.",
  "@quiz2faQ1Explain": {
    "description": "quiz2faQ1Explain"
  },
  "hygieneUpdateDescBeginner": "Install updates as soon as they appear - they fix holes that viruses use to break in.",
  "@hygieneUpdateDescBeginner": {
    "description": "hygieneUpdateDescBeginner"
  },
  "hygieneUpdateDescAdvanced": "Apply OS and application patches promptly. Zero-day exploits target known CVEs within hours of disclosure.",
  "@hygieneUpdateDescAdvanced": {
    "description": "hygieneUpdateDescAdvanced"
  },
  "hygienePasswordDescBeginner": "Use a different long password for every site. A password manager remembers them all for you.",
  "@hygienePasswordDescBeginner": {
    "description": "hygienePasswordDescBeginner"
  },
  "hygienePasswordDescAdvanced": "Use a password manager with unique 16+ char credentials per service. Enable breach monitoring (HaveIBeenPwned).",
  "@hygienePasswordDescAdvanced": {
    "description": "hygienePasswordDescAdvanced"
  },
  "hygienePhishingDescBeginner": "Don't click links in suspicious emails. Always check who sent the message and where the link actually goes.",
  "@hygienePhishingDescBeginner": {
    "description": "hygienePhishingDescBeginner"
  },
  "hygienePhishingDescAdvanced": "Verify sender SPF/DKIM headers, inspect link destinations via hover, watch for homoglyph domains and URL shorteners.",
  "@hygienePhishingDescAdvanced": {
    "description": "hygienePhishingDescAdvanced"
  },
  "hygieneDownloadDescBeginner": "Only download programs from official websites. Cracked software almost always contains viruses.",
  "@hygieneDownloadDescBeginner": {
    "description": "hygieneDownloadDescBeginner"
  },
  "hygieneDownloadDescAdvanced": "Verify file hashes and digital signatures before execution. Use sandboxing for untrusted binaries.",
  "@hygieneDownloadDescAdvanced": {
    "description": "hygieneDownloadDescAdvanced"
  },
  "hygieneWifiDescBeginner": "Don't enter passwords or bank details on public Wi-Fi. Use mobile data or a VPN instead.",
  "@hygieneWifiDescBeginner": {
    "description": "hygieneWifiDescBeginner"
  },
  "hygieneWifiDescAdvanced": "Public networks enable MITM/ARP spoofing. Use WireGuard/OpenVPN; verify TLS certificate pinning on critical services.",
  "@hygieneWifiDescAdvanced": {
    "description": "hygieneWifiDescAdvanced"
  },
  "hygiene2faDescBeginner": "Turn on two-factor authentication - even if someone steals your password, they still can't log in.",
  "@hygiene2faDescBeginner": {
    "description": "hygiene2faDescBeginner"
  },
  "hygiene2faDescAdvanced": "Enable TOTP or FIDO2/WebAuthn. Avoid SMS-based 2FA where possible due to SIM-swap attacks.",
  "@hygiene2faDescAdvanced": {
    "description": "hygiene2faDescAdvanced"
  },
  "quizRetake": "Retake quiz",
  "@quizRetake": {
    "description": "quizRetake"
  },
  "quizUpdateQ1A4": "Updates are optional and not important",
  "@quizUpdateQ1A4": {
    "description": "quizUpdateQ1A4"
  },
  "quizUpdateQ2A4": "Only install updates once a year",
  "@quizUpdateQ2A4": {
    "description": "quizUpdateQ2A4"
  },
  "quizUpdateQ3": "What is a zero-day vulnerability?",
  "@quizUpdateQ3": {
    "description": "quizUpdateQ3"
  },
  "quizUpdateQ3A1": "A flaw exploited before the developer releases a patch",
  "@quizUpdateQ3A1": {
    "description": "quizUpdateQ3A1"
  },
  "quizUpdateQ3A2": "A virus that activates at midnight",
  "@quizUpdateQ3A2": {
    "description": "quizUpdateQ3A2"
  },
  "quizUpdateQ3A3": "A computer that has been on for zero days",
  "@quizUpdateQ3A3": {
    "description": "quizUpdateQ3A3"
  },
  "quizUpdateQ3A4": "A password that expires in zero days",
  "@quizUpdateQ3A4": {
    "description": "quizUpdateQ3A4"
  },
  "quizUpdateQ3Explain": "Zero-day means the developer has had 'zero days' to fix it. These are the most dangerous because no patch exists yet. Keeping software updated reduces the window of exposure.",
  "@quizUpdateQ3Explain": {
    "description": "quizUpdateQ3Explain"
  },
  "quizPasswordQ1A4": "A single word from the dictionary: 'sunshine'",
  "@quizPasswordQ1A4": {
    "description": "quizPasswordQ1A4"
  },
  "quizPasswordQ2A4": "Browsers remember passwords automatically, no need to worry",
  "@quizPasswordQ2A4": {
    "description": "quizPasswordQ2A4"
  },
  "quizPasswordQ3": "What is a password manager?",
  "@quizPasswordQ3": {
    "description": "quizPasswordQ3"
  },
  "quizPasswordQ3A1": "A program that generates and securely stores unique passwords for each service",
  "@quizPasswordQ3A1": {
    "description": "quizPasswordQ3A1"
  },
  "quizPasswordQ3A2": "A browser extension that shows saved passwords in plain text",
  "@quizPasswordQ3A2": {
    "description": "quizPasswordQ3A2"
  },
  "quizPasswordQ3A3": "A text file where you write down all your passwords",
  "@quizPasswordQ3A3": {
    "description": "quizPasswordQ3A3"
  },
  "quizPasswordQ3A4": "A setting in Windows that remembers your login",
  "@quizPasswordQ3A4": {
    "description": "quizPasswordQ3A4"
  },
  "quizPasswordQ3Explain": "Password managers encrypt your vault with a master password. They generate random unique passwords, auto-fill login forms, and alert you about breaches.",
  "@quizPasswordQ3Explain": {
    "description": "quizPasswordQ3Explain"
  },
  "quizPhishingQ1A4": "Reply asking them to verify their identity",
  "@quizPhishingQ1A4": {
    "description": "quizPhishingQ1A4"
  },
  "quizPhishingQ2A4": "Click a link from social media",
  "@quizPhishingQ2A4": {
    "description": "quizPhishingQ2A4"
  },
  "quizPhishingQ3A4": "HTTPS doesn't matter at all",
  "@quizPhishingQ3A4": {
    "description": "quizPhishingQ3A4"
  },
  "quizDownloadQ1A4": "A link from a stranger in a messaging app",
  "@quizDownloadQ1A4": {
    "description": "quizDownloadQ1A4"
  },
  "quizDownloadQ2A4": "It's a compressed PDF for faster download",
  "@quizDownloadQ2A4": {
    "description": "quizDownloadQ2A4"
  },
  "quizDownloadQ3": "What should you check before running a downloaded program?",
  "@quizDownloadQ3": {
    "description": "quizDownloadQ3"
  },
  "quizDownloadQ3A1": "Its digital signature - a valid signature confirms the publisher's identity",
  "@quizDownloadQ3A1": {
    "description": "quizDownloadQ3A1"
  },
  "quizDownloadQ3A2": "The file size - larger files are always safer",
  "@quizDownloadQ3A2": {
    "description": "quizDownloadQ3A2"
  },
  "quizDownloadQ3A3": "The file icon - legitimate programs have professional icons",
  "@quizDownloadQ3A3": {
    "description": "quizDownloadQ3A3"
  },
  "quizDownloadQ3A4": "Nothing - if the antivirus didn't block it, it's safe",
  "@quizDownloadQ3A4": {
    "description": "quizDownloadQ3A4"
  },
  "quizDownloadQ3Explain": "Digital signatures verify that the file comes from the claimed publisher and hasn't been tampered with. Unsigned executables from the internet should be treated with extra caution.",
  "@quizDownloadQ3Explain": {
    "description": "quizDownloadQ3Explain"
  },
  "quizWifiQ1A4": "Public Wi-Fi is only dangerous if the network has no password",
  "@quizWifiQ1A4": {
    "description": "quizWifiQ1A4"
  },
  "quizWifiQ2": "What is a VPN and why use it on public Wi-Fi?",
  "@quizWifiQ2": {
    "description": "quizWifiQ2"
  },
  "quizWifiQ2A1": "It encrypts all your traffic through a secure tunnel, hiding it from network attackers",
  "@quizWifiQ2A1": {
    "description": "quizWifiQ2A1"
  },
  "quizWifiQ2A2": "It makes your internet faster",
  "@quizWifiQ2A2": {
    "description": "quizWifiQ2A2"
  },
  "quizWifiQ2A3": "It blocks all viruses automatically",
  "@quizWifiQ2A3": {
    "description": "quizWifiQ2A3"
  },
  "quizWifiQ2A4": "It replaces your antivirus",
  "@quizWifiQ2A4": {
    "description": "quizWifiQ2A4"
  },
  "quizWifiQ2Explain": "A VPN (Virtual Private Network) creates an encrypted tunnel between your device and a server. Even if an attacker intercepts your traffic on public Wi-Fi, they only see encrypted data.",
  "@quizWifiQ2Explain": {
    "description": "quizWifiQ2Explain"
  },
  "quizWifiQ3": "You see a Wi-Fi network called 'Free_Airport_WiFi' at the airport. What is the risk?",
  "@quizWifiQ3": {
    "description": "quizWifiQ3"
  },
  "quizWifiQ3A1": "It could be a fake hotspot set up by an attacker to intercept your data",
  "@quizWifiQ3A1": {
    "description": "quizWifiQ3A1"
  },
  "quizWifiQ3A2": "Free networks are always safe at airports",
  "@quizWifiQ3A2": {
    "description": "quizWifiQ3A2"
  },
  "quizWifiQ3A3": "The only risk is slow speed",
  "@quizWifiQ3A3": {
    "description": "quizWifiQ3A3"
  },
  "quizWifiQ3A4": "Airport Wi-Fi is monitored by security, so it's always safe",
  "@quizWifiQ3A4": {
    "description": "quizWifiQ3A4"
  },
  "quizWifiQ3Explain": "Evil twin attacks create fake hotspots mimicking legitimate networks. Always verify the official network name with staff and use a VPN.",
  "@quizWifiQ3Explain": {
    "description": "quizWifiQ3Explain"
  },
  "quiz2faQ1A4": "Having two email accounts",
  "@quiz2faQ1A4": {
    "description": "quiz2faQ1A4"
  },
  "quiz2faQ2": "Which 2FA method is the most secure?",
  "@quiz2faQ2": {
    "description": "quiz2faQ2"
  },
  "quiz2faQ2A1": "A hardware key (FIDO2/YubiKey) or authenticator app (TOTP)",
  "@quiz2faQ2A1": {
    "description": "quiz2faQ2A1"
  },
  "quiz2faQ2A2": "SMS codes sent to your phone",
  "@quiz2faQ2A2": {
    "description": "quiz2faQ2A2"
  },
  "quiz2faQ2A3": "Email verification links",
  "@quiz2faQ2A3": {
    "description": "quiz2faQ2A3"
  },
  "quiz2faQ2A4": "Security questions (mother's maiden name, etc.)",
  "@quiz2faQ2A4": {
    "description": "quiz2faQ2A4"
  },
  "quiz2faQ2Explain": "Hardware keys and TOTP apps are resistant to phishing and SIM-swap attacks. SMS codes can be intercepted via SIM cloning. Security questions are easily guessable from social media.",
  "@quiz2faQ2Explain": {
    "description": "quiz2faQ2Explain"
  },
  "quiz2faQ3": "You lose your phone with the authenticator app. What should you have prepared?",
  "@quiz2faQ3": {
    "description": "quiz2faQ3"
  },
  "quiz2faQ3A1": "Backup recovery codes stored in a safe place",
  "@quiz2faQ3A1": {
    "description": "quiz2faQ3A1"
  },
  "quiz2faQ3A2": "Nothing - you can always call support",
  "@quiz2faQ3A2": {
    "description": "quiz2faQ3A2"
  },
  "quiz2faQ3A3": "Another phone with the same app installed",
  "@quiz2faQ3A3": {
    "description": "quiz2faQ3A3"
  },
  "quiz2faQ3A4": "Your password is enough to recover access",
  "@quiz2faQ3A4": {
    "description": "quiz2faQ3A4"
  },
  "quiz2faQ3Explain": "Most services provide one-time backup codes when you set up 2FA. Store them offline (printed or in a password manager) - they are your emergency access if you lose your device.",
  "@quiz2faQ3Explain": {
    "description": "quiz2faQ3Explain"
  },
  "quizBackupQ1": "What is the 3-2-1 backup rule?",
  "@quizBackupQ1": {
    "description": "quizBackupQ1"
  },
  "quizBackupQ1A1": "3 copies of data, on 2 different media types, with 1 copy offsite",
  "@quizBackupQ1A1": {
    "description": "quizBackupQ1A1"
  },
  "quizBackupQ1A2": "Back up 3 files, 2 times a day, to 1 drive",
  "@quizBackupQ1A2": {
    "description": "quizBackupQ1A2"
  },
  "quizBackupQ1A3": "Use 3 passwords, 2 accounts, 1 computer",
  "@quizBackupQ1A3": {
    "description": "quizBackupQ1A3"
  },
  "quizBackupQ1A4": "3 antivirus programs, 2 firewalls, 1 VPN",
  "@quizBackupQ1A4": {
    "description": "quizBackupQ1A4"
  },
  "quizBackupQ1Explain": "The 3-2-1 rule ensures that no single failure (hardware crash, ransomware, fire) can destroy all your data. Offsite means cloud or a physically separate location.",
  "@quizBackupQ1Explain": {
    "description": "quizBackupQ1Explain"
  },
  "quizBackupQ2": "How can ransomware affect your backups?",
  "@quizBackupQ2": {
    "description": "quizBackupQ2"
  },
  "quizBackupQ2A1": "It can encrypt backups stored on connected drives, making them useless",
  "@quizBackupQ2A1": {
    "description": "quizBackupQ2A1"
  },
  "quizBackupQ2A2": "Ransomware only affects the operating system, not data files",
  "@quizBackupQ2A2": {
    "description": "quizBackupQ2A2"
  },
  "quizBackupQ2A3": "Backups are immune to ransomware",
  "@quizBackupQ2A3": {
    "description": "quizBackupQ2A3"
  },
  "quizBackupQ2A4": "Ransomware cannot spread to external drives",
  "@quizBackupQ2A4": {
    "description": "quizBackupQ2A4"
  },
  "quizBackupQ2Explain": "Ransomware encrypts everything it can access, including mounted backup drives. Keep at least one backup offline (disconnected) or use versioned cloud backups with immutable snapshots.",
  "@quizBackupQ2Explain": {
    "description": "quizBackupQ2Explain"
  },
  "quizBackupQ3": "How often should you test your backups?",
  "@quizBackupQ3": {
    "description": "quizBackupQ3"
  },
  "quizBackupQ3A1": "Regularly - a backup you've never tested might be corrupted or incomplete",
  "@quizBackupQ3A1": {
    "description": "quizBackupQ3A1"
  },
  "quizBackupQ3A2": "Never - if the backup completed without errors, it works",
  "@quizBackupQ3A2": {
    "description": "quizBackupQ3A2"
  },
  "quizBackupQ3A3": "Only after a disaster happens",
  "@quizBackupQ3A3": {
    "description": "quizBackupQ3A3"
  },
  "quizBackupQ3A4": "Once when you first set up the backup",
  "@quizBackupQ3A4": {
    "description": "quizBackupQ3A4"
  },
  "quizBackupQ3Explain": "Untested backups may contain corrupted files, missing data, or incompatible formats. Schedule periodic restore tests to verify your recovery process actually works.",
  "@quizBackupQ3Explain": {
    "description": "quizBackupQ3Explain"
  },
  "quizUsbQ1": "You find a USB drive in the parking lot. What should you do?",
  "@quizUsbQ1": {
    "description": "quizUsbQ1"
  },
  "quizUsbQ1A1": "Do NOT plug it in - it could contain malware that runs automatically",
  "@quizUsbQ1A1": {
    "description": "quizUsbQ1A1"
  },
  "quizUsbQ1A2": "Plug it in to find the owner's contact information",
  "@quizUsbQ1A2": {
    "description": "quizUsbQ1A2"
  },
  "quizUsbQ1A3": "Scan it with antivirus first, then it's safe to open",
  "@quizUsbQ1A3": {
    "description": "quizUsbQ1A3"
  },
  "quizUsbQ1A4": "Format it and use it as your own",
  "@quizUsbQ1A4": {
    "description": "quizUsbQ1A4"
  },
  "quizUsbQ1Explain": "USB drop attacks are a real social engineering technique. Malicious USB devices can execute code automatically (BadUSB), install backdoors, or even physically damage hardware (USB Killer).",
  "@quizUsbQ1Explain": {
    "description": "quizUsbQ1Explain"
  },
  "quizUsbQ2": "What is a 'BadUSB' attack?",
  "@quizUsbQ2": {
    "description": "quizUsbQ2"
  },
  "quizUsbQ2A1": "A USB device that pretends to be a keyboard and types malicious commands",
  "@quizUsbQ2A1": {
    "description": "quizUsbQ2A1"
  },
  "quizUsbQ2A2": "A broken USB cable that damages your port",
  "@quizUsbQ2A2": {
    "description": "quizUsbQ2A2"
  },
  "quizUsbQ2A3": "A virus that spreads through USB hubs",
  "@quizUsbQ2A3": {
    "description": "quizUsbQ2A3"
  },
  "quizUsbQ2A4": "A fake USB charger that charges too slowly",
  "@quizUsbQ2A4": {
    "description": "quizUsbQ2A4"
  },
  "quizUsbQ2Explain": "BadUSB reprograms the USB controller firmware to impersonate a keyboard. It can type commands at superhuman speed, downloading and executing malware in seconds.",
  "@quizUsbQ2Explain": {
    "description": "quizUsbQ2Explain"
  },
  "quizUsbQ3": "How can you safely use USB drives at work?",
  "@quizUsbQ3": {
    "description": "quizUsbQ3"
  },
  "quizUsbQ3A1": "Only use company-approved encrypted drives and disable autorun",
  "@quizUsbQ3A1": {
    "description": "quizUsbQ3A1"
  },
  "quizUsbQ3A2": "Any USB drive is fine as long as you scan it first",
  "@quizUsbQ3A2": {
    "description": "quizUsbQ3A2"
  },
  "quizUsbQ3A3": "Only use drives from trusted colleagues",
  "@quizUsbQ3A3": {
    "description": "quizUsbQ3A3"
  },
  "quizUsbQ3A4": "USB drives are outdated and never needed",
  "@quizUsbQ3A4": {
    "description": "quizUsbQ3A4"
  },
  "quizUsbQ3Explain": "Company-approved encrypted drives prevent data leaks if lost. Disabling autorun stops malware from executing automatically when a drive is inserted.",
  "@quizUsbQ3Explain": {
    "description": "quizUsbQ3Explain"
  },
  "quizPrivacyQ1": "What information can websites collect about you without cookies?",
  "@quizPrivacyQ1": {
    "description": "quizPrivacyQ1"
  },
  "quizPrivacyQ1A1": "Browser fingerprint: screen resolution, installed fonts, timezone, and more",
  "@quizPrivacyQ1A1": {
    "description": "quizPrivacyQ1A1"
  },
  "quizPrivacyQ1A2": "Nothing at all - cookies are the only tracking method",
  "@quizPrivacyQ1A2": {
    "description": "quizPrivacyQ1A2"
  },
  "quizPrivacyQ1A3": "Only your IP address",
  "@quizPrivacyQ1A3": {
    "description": "quizPrivacyQ1A3"
  },
  "quizPrivacyQ1A4": "Only the pages you visit on that specific site",
  "@quizPrivacyQ1A4": {
    "description": "quizPrivacyQ1A4"
  },
  "quizPrivacyQ1Explain": "Browser fingerprinting combines dozens of technical details (screen size, GPU, fonts, timezone, language) into a unique identifier. Even without cookies, ~95% of users can be uniquely identified.",
  "@quizPrivacyQ1Explain": {
    "description": "quizPrivacyQ1Explain"
  },
  "quizPrivacyQ2": "Why should you review app permissions on your phone?",
  "@quizPrivacyQ2": {
    "description": "quizPrivacyQ2"
  },
  "quizPrivacyQ2A1": "Apps may request access to camera, microphone, or contacts beyond what they need",
  "@quizPrivacyQ2A1": {
    "description": "quizPrivacyQ2A1"
  },
  "quizPrivacyQ2A2": "Permissions are always necessary for the app to function",
  "@quizPrivacyQ2A2": {
    "description": "quizPrivacyQ2A2"
  },
  "quizPrivacyQ2A3": "It's only important for paid apps",
  "@quizPrivacyQ2A3": {
    "description": "quizPrivacyQ2A3"
  },
  "quizPrivacyQ2A4": "Permissions don't affect your privacy",
  "@quizPrivacyQ2A4": {
    "description": "quizPrivacyQ2A4"
  },
  "quizPrivacyQ2Explain": "A flashlight app doesn't need access to your contacts or microphone. Excessive permissions may indicate data harvesting. Review and revoke unnecessary permissions regularly.",
  "@quizPrivacyQ2Explain": {
    "description": "quizPrivacyQ2Explain"
  },
  "quizPrivacyQ3": "What is the safest approach to social media privacy?",
  "@quizPrivacyQ3": {
    "description": "quizPrivacyQ3"
  },
  "quizPrivacyQ3A1": "Set profiles to private and limit personal information shared publicly",
  "@quizPrivacyQ3A1": {
    "description": "quizPrivacyQ3A1"
  },
  "quizPrivacyQ3A2": "Public profiles are fine - only friends see your posts",
  "@quizPrivacyQ3A2": {
    "description": "quizPrivacyQ3A2"
  },
  "quizPrivacyQ3A3": "Share everything - transparency is modern",
  "@quizPrivacyQ3A3": {
    "description": "quizPrivacyQ3A3"
  },
  "quizPrivacyQ3A4": "Use a fake name and share freely",
  "@quizPrivacyQ3A4": {
    "description": "quizPrivacyQ3A4"
  },
  "quizPrivacyQ3Explain": "Public profiles expose personal data to social engineering attacks. Attackers use birthdays, pet names, school names to guess passwords and security questions.",
  "@quizPrivacyQ3Explain": {
    "description": "quizPrivacyQ3Explain"
  },
  "quizLockQ1": "Why should your computer lock automatically after a few minutes?",
  "@quizLockQ1": {
    "description": "quizLockQ1"
  },
  "quizLockQ1A1": "Anyone nearby could access your files, email, and accounts while you're away",
  "@quizLockQ1A1": {
    "description": "quizLockQ1A1"
  },
  "quizLockQ1A2": "It saves battery power",
  "@quizLockQ1A2": {
    "description": "quizLockQ1A2"
  },
  "quizLockQ1A3": "It prevents the screen from burning in",
  "@quizLockQ1A3": {
    "description": "quizLockQ1A3"
  },
  "quizLockQ1A4": "It's only important in offices, not at home",
  "@quizLockQ1A4": {
    "description": "quizLockQ1A4"
  },
  "quizLockQ1Explain": "An unlocked computer is an open door. In seconds, someone can install malware, copy files, or access your accounts. Set auto-lock to 5 minutes or less.",
  "@quizLockQ1Explain": {
    "description": "quizLockQ1Explain"
  },
  "quizLockQ2": "Which is the safest way to unlock your computer?",
  "@quizLockQ2": {
    "description": "quizLockQ2"
  },
  "quizLockQ2A1": "Biometrics (fingerprint/face) or a strong PIN combined with TPM",
  "@quizLockQ2A1": {
    "description": "quizLockQ2A1"
  },
  "quizLockQ2A2": "A simple 4-digit PIN like 1234",
  "@quizLockQ2A2": {
    "description": "quizLockQ2A2"
  },
  "quizLockQ2A3": "No password - it's faster",
  "@quizLockQ2A3": {
    "description": "quizLockQ2A3"
  },
  "quizLockQ2A4": "A pattern drawn on the screen",
  "@quizLockQ2A4": {
    "description": "quizLockQ2A4"
  },
  "quizLockQ2Explain": "Windows Hello biometrics + TPM provides strong local authentication. Simple PINs are easily guessable, and patterns can be observed or smudge-traced.",
  "@quizLockQ2Explain": {
    "description": "quizLockQ2Explain"
  },
  "quizLockQ3": "What is Windows Hello?",
  "@quizLockQ3": {
    "description": "quizLockQ3"
  },
  "quizLockQ3A1": "A built-in authentication system using fingerprint, face recognition, or secure PIN",
  "@quizLockQ3A1": {
    "description": "quizLockQ3A1"
  },
  "quizLockQ3A2": "A greeting message when Windows starts",
  "@quizLockQ3A2": {
    "description": "quizLockQ3A2"
  },
  "quizLockQ3A3": "A voice assistant like Cortana",
  "@quizLockQ3A3": {
    "description": "quizLockQ3A3"
  },
  "quizLockQ3A4": "A parental control feature",
  "@quizLockQ3A4": {
    "description": "quizLockQ3A4"
  },
  "quizLockQ3Explain": "Windows Hello stores biometric data locally in TPM hardware, not in the cloud. It's more secure than passwords because biometrics can't be phished or reused across services.",
  "@quizLockQ3Explain": {
    "description": "quizLockQ3Explain"
  },
  "quizExtQ1": "What risk do browser extensions pose?",
  "@quizExtQ1": {
    "description": "quizExtQ1"
  },
  "quizExtQ1A1": "They can read all data on every page you visit, including passwords and bank details",
  "@quizExtQ1A1": {
    "description": "quizExtQ1A1"
  },
  "quizExtQ1A2": "They only affect the browser's appearance",
  "@quizExtQ1A2": {
    "description": "quizExtQ1A2"
  },
  "quizExtQ1A3": "Extensions from the official store are always safe",
  "@quizExtQ1A3": {
    "description": "quizExtQ1A3"
  },
  "quizExtQ1A4": "They can slow down the browser but nothing more",
  "@quizExtQ1A4": {
    "description": "quizExtQ1A4"
  },
  "quizExtQ1Explain": "Extensions with 'Read and change all your data on all websites' permission can see everything: passwords, credit cards, private messages. Only install extensions you truly need.",
  "@quizExtQ1Explain": {
    "description": "quizExtQ1Explain"
  },
  "quizExtQ2": "How should you choose which extensions to install?",
  "@quizExtQ2": {
    "description": "quizExtQ2"
  },
  "quizExtQ2A1": "Install only essential ones from known developers, check permissions and reviews",
  "@quizExtQ2A1": {
    "description": "quizExtQ2A1"
  },
  "quizExtQ2A2": "Install as many as possible for maximum functionality",
  "@quizExtQ2A2": {
    "description": "quizExtQ2A2"
  },
  "quizExtQ2A3": "Only look at the star rating",
  "@quizExtQ2A3": {
    "description": "quizExtQ2A3"
  },
  "quizExtQ2A4": "Friends' recommendations are always trustworthy",
  "@quizExtQ2A4": {
    "description": "quizExtQ2A4"
  },
  "quizExtQ2Explain": "Even popular extensions can be sold to malicious actors who push a trojanized update. Minimize installed extensions, review permissions, and remove ones you no longer use.",
  "@quizExtQ2Explain": {
    "description": "quizExtQ2Explain"
  },
  "quizExtQ3": "An extension you've used for months suddenly requests new permissions. What do you do?",
  "@quizExtQ3": {
    "description": "quizExtQ3"
  },
  "quizExtQ3A1": "Be suspicious - it may have been sold or compromised; research before accepting",
  "@quizExtQ3A1": {
    "description": "quizExtQ3A1"
  },
  "quizExtQ3A2": "Accept immediately - updates always need new permissions",
  "@quizExtQ3A2": {
    "description": "quizExtQ3A2"
  },
  "quizExtQ3A3": "Ignore the notification",
  "@quizExtQ3A3": {
    "description": "quizExtQ3A3"
  },
  "quizExtQ3A4": "Uninstall and reinstall to fix the bug",
  "@quizExtQ3A4": {
    "description": "quizExtQ3A4"
  },
  "quizExtQ3Explain": "Extension ownership can change hands. New owners may add tracking, ad injection, or data theft. Always research why new permissions are needed before granting them.",
  "@quizExtQ3Explain": {
    "description": "quizExtQ3Explain"
  },
  "quizEncryptQ1": "What does full disk encryption (BitLocker) protect against?",
  "@quizEncryptQ1": {
    "description": "quizEncryptQ1"
  },
  "quizEncryptQ1A1": "Someone reading your data if the laptop is stolen or the drive is removed",
  "@quizEncryptQ1A1": {
    "description": "quizEncryptQ1A1"
  },
  "quizEncryptQ1A2": "Viruses and malware",
  "@quizEncryptQ1A2": {
    "description": "quizEncryptQ1A2"
  },
  "quizEncryptQ1A3": "Data loss from hardware failure",
  "@quizEncryptQ1A3": {
    "description": "quizEncryptQ1A3"
  },
  "quizEncryptQ1A4": "Hackers accessing your computer over the network",
  "@quizEncryptQ1A4": {
    "description": "quizEncryptQ1A4"
  },
  "quizEncryptQ1Explain": "Disk encryption protects data at rest. If someone steals your laptop, they cannot read the drive without your encryption key. It does NOT protect against malware or network attacks.",
  "@quizEncryptQ1Explain": {
    "description": "quizEncryptQ1Explain"
  },
  "quizEncryptQ2": "What happens to encrypted data if you forget the recovery key?",
  "@quizEncryptQ2": {
    "description": "quizEncryptQ2"
  },
  "quizEncryptQ2A1": "The data becomes permanently inaccessible - there is no backdoor",
  "@quizEncryptQ2A1": {
    "description": "quizEncryptQ2A1"
  },
  "quizEncryptQ2A2": "Microsoft can recover it for you",
  "@quizEncryptQ2A2": {
    "description": "quizEncryptQ2A2"
  },
  "quizEncryptQ2A3": "The data is only temporarily locked for 24 hours",
  "@quizEncryptQ2A3": {
    "description": "quizEncryptQ2A3"
  },
  "quizEncryptQ2A4": "You can bypass encryption with Safe Mode",
  "@quizEncryptQ2A4": {
    "description": "quizEncryptQ2A4"
  },
  "quizEncryptQ2Explain": "Strong encryption means even the manufacturer cannot recover your data without the key. Save your BitLocker recovery key in your Microsoft account or print it and store it safely.",
  "@quizEncryptQ2Explain": {
    "description": "quizEncryptQ2Explain"
  },
  "quizEncryptQ3": "When should you use encrypted messaging (Signal, WhatsApp)?",
  "@quizEncryptQ3": {
    "description": "quizEncryptQ3"
  },
  "quizEncryptQ3A1": "For any sensitive conversations - end-to-end encryption prevents interception",
  "@quizEncryptQ3A1": {
    "description": "quizEncryptQ3A1"
  },
  "quizEncryptQ3A2": "Only for illegal activities",
  "@quizEncryptQ3A2": {
    "description": "quizEncryptQ3A2"
  },
  "quizEncryptQ3A3": "Regular messaging apps are equally secure",
  "@quizEncryptQ3A3": {
    "description": "quizEncryptQ3A3"
  },
  "quizEncryptQ3A4": "Encryption is only needed for businesses",
  "@quizEncryptQ3A4": {
    "description": "quizEncryptQ3A4"
  },
  "quizEncryptQ3Explain": "End-to-end encryption ensures only you and the recipient can read messages. Not even the service provider can access them. Use it for personal, financial, or medical discussions.",
  "@quizEncryptQ3Explain": {
    "description": "quizEncryptQ3Explain"
  },
  "quizUpdateQ4": "What is the danger of using End of Life (EOL) software?",
  "@quizUpdateQ4": {
    "description": "quizUpdateQ4"
  },
  "quizUpdateQ4A1": "Security patches are no longer released, leaving vulnerabilities permanently open",
  "@quizUpdateQ4A1": {
    "description": "quizUpdateQ4A1"
  },
  "quizUpdateQ4A2": "It runs slower than newer versions",
  "@quizUpdateQ4A2": {
    "description": "quizUpdateQ4A2"
  },
  "quizUpdateQ4A3": "It takes up more disk space",
  "@quizUpdateQ4A3": {
    "description": "quizUpdateQ4A3"
  },
  "quizUpdateQ4A4": "The developer can delete it remotely",
  "@quizUpdateQ4A4": {
    "description": "quizUpdateQ4A4"
  },
  "quizUpdateQ4Explain": "End-of-life software (like Windows 7) no longer receives security updates. All discovered vulnerabilities remain open forever, making the system an easy target for attackers.",
  "@quizUpdateQ4Explain": {
    "description": "quizUpdateQ4Explain"
  },
  "quizUpdateQ5": "What risk does auto-updating carry?",
  "@quizUpdateQ5": {
    "description": "quizUpdateQ5"
  },
  "quizUpdateQ5A1": "Minimal - security benefits outweigh rare glitches",
  "@quizUpdateQ5A1": {
    "description": "quizUpdateQ5A1"
  },
  "quizUpdateQ5A2": "High - updates always break the system",
  "@quizUpdateQ5A2": {
    "description": "quizUpdateQ5A2"
  },
  "quizUpdateQ5A3": "None - updates cannot be tampered with",
  "@quizUpdateQ5A3": {
    "description": "quizUpdateQ5A3"
  },
  "quizUpdateQ5A4": "Updates permanently slow down the computer",
  "@quizUpdateQ5A4": {
    "description": "quizUpdateQ5A4"
  },
  "quizUpdateQ5Explain": "Auto-update is best practice: it patches vulnerabilities faster than attackers can exploit them. Rare glitches after updates are easily fixable, but unpatched vulnerabilities are not.",
  "@quizUpdateQ5Explain": {
    "description": "quizUpdateQ5Explain"
  },
  "quizPasswordQ4": "What makes a password truly strong?",
  "@quizPasswordQ4": {
    "description": "quizPasswordQ4"
  },
  "quizPasswordQ4A1": "Length of 12+ characters and randomness - not dictionary words or personal data",
  "@quizPasswordQ4A1": {
    "description": "quizPasswordQ4A1"
  },
  "quizPasswordQ4A2": "Replacing letters with symbols: P@$$w0rd",
  "@quizPasswordQ4A2": {
    "description": "quizPasswordQ4A2"
  },
  "quizPasswordQ4A3": "Using your birthdate - easy to remember",
  "@quizPasswordQ4A3": {
    "description": "quizPasswordQ4A3"
  },
  "quizPasswordQ4A4": "Short but with an exclamation mark: Go!1",
  "@quizPasswordQ4A4": {
    "description": "quizPasswordQ4A4"
  },
  "quizPasswordQ4Explain": "Length matters more than complexity. A 12-character random lowercase password is stronger than an 8-character one with special characters. Substitutions (@=a, 0=o) have long been in attackers' dictionaries.",
  "@quizPasswordQ4Explain": {
    "description": "quizPasswordQ4Explain"
  },
  "quizPasswordQ5": "Why is password reuse dangerous?",
  "@quizPasswordQ5": {
    "description": "quizPasswordQ5"
  },
  "quizPasswordQ5A1": "A breach on one site gives attackers access to all your accounts",
  "@quizPasswordQ5A1": {
    "description": "quizPasswordQ5A1"
  },
  "quizPasswordQ5A2": "Websites will know you're the same person",
  "@quizPasswordQ5A2": {
    "description": "quizPasswordQ5A2"
  },
  "quizPasswordQ5A3": "The browser will stop saving passwords",
  "@quizPasswordQ5A3": {
    "description": "quizPasswordQ5A3"
  },
  "quizPasswordQ5A4": "It's prohibited by security policy",
  "@quizPasswordQ5A4": {
    "description": "quizPasswordQ5A4"
  },
  "quizPasswordQ5Explain": "Credential stuffing is an attack where stolen login/password pairs are automatically tested on hundreds of services. If your password is the same everywhere, one breach opens access to everything.",
  "@quizPasswordQ5Explain": {
    "description": "quizPasswordQ5Explain"
  },
  "quizWifiQ4": "What is a captive portal and why is it risky?",
  "@quizWifiQ4": {
    "description": "quizWifiQ4"
  },
  "quizWifiQ4A1": "A login page on public Wi-Fi - can be spoofed to steal credentials",
  "@quizWifiQ4A1": {
    "description": "quizWifiQ4A1"
  },
  "quizWifiQ4A2": "A program to speed up Wi-Fi",
  "@quizWifiQ4A2": {
    "description": "quizWifiQ4A2"
  },
  "quizWifiQ4A3": "A secure hotspot in a cafe",
  "@quizWifiQ4A3": {
    "description": "quizWifiQ4A3"
  },
  "quizWifiQ4A4": "An antivirus for routers",
  "@quizWifiQ4A4": {
    "description": "quizWifiQ4A4"
  },
  "quizWifiQ4Explain": "A captive portal is the login page you see on public Wi-Fi. An attacker can create a fake hotspot with a similar name and spoof the login page to harvest credentials.",
  "@quizWifiQ4Explain": {
    "description": "quizWifiQ4Explain"
  },
  "quizWifiQ5": "What advantage does WPA3 have over WPA2?",
  "@quizWifiQ5": {
    "description": "quizWifiQ5"
  },
  "quizWifiQ5A1": "Protects against traffic interception even with weak passwords thanks to SAE protocol",
  "@quizWifiQ5A1": {
    "description": "quizWifiQ5A1"
  },
  "quizWifiQ5A2": "Works 3x faster",
  "@quizWifiQ5A2": {
    "description": "quizWifiQ5A2"
  },
  "quizWifiQ5A3": "Doesn't require a password at all",
  "@quizWifiQ5A3": {
    "description": "quizWifiQ5A3"
  },
  "quizWifiQ5A4": "Supports more devices",
  "@quizWifiQ5A4": {
    "description": "quizWifiQ5A4"
  },
  "quizWifiQ5Explain": "WPA3 uses the SAE (Simultaneous Authentication of Equals) protocol, which protects against offline password brute-forcing and KRACK-type attacks. Even with a weak password, intercepting traffic is significantly harder.",
  "@quizWifiQ5Explain": {
    "description": "quizWifiQ5Explain"
  },
  "quizPhishingQ4": "What is spear-phishing?",
