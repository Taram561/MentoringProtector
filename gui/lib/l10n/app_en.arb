  },
  "quizPhishingQ5A2": "Click and see what opens",
  "@quizPhishingQ5A2": {
    "description": "quizPhishingQ5A2"
  },
  "quizPhishingQ5A3": "Check if the link looks nice",
  "@quizPhishingQ5A3": {
    "description": "quizPhishingQ5A3"
  },
  "quizPhishingQ5A4": "Links are always safe if they came by email",
  "@quizPhishingQ5A4": {
    "description": "quizPhishingQ5A4"
  },
  "quizPhishingQ5Explain": "Before clicking, hover over the link - the real URL appears in the browser status bar. Check the domain: gooogle.com, paypa1.com, sberbank-online.xyz are all phishing signs.",
