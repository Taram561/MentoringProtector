  "quizPrivacyQ5": "What do tracking cookies do?",
  "@quizPrivacyQ5": {
    "description": "quizPrivacyQ5"
  },
  "quizPrivacyQ5A1": "Track your behavior across websites to build an advertising profile",
  "@quizPrivacyQ5A1": {
    "description": "quizPrivacyQ5A1"
  },
  "quizPrivacyQ5A2": "Speed up page loading",
  "@quizPrivacyQ5A2": {
    "description": "quizPrivacyQ5A2"
  },
  "quizPrivacyQ5A3": "Protect against viruses",
  "@quizPrivacyQ5A3": {
    "description": "quizPrivacyQ5A3"
  },
  "quizPrivacyQ5A4": "Save website passwords",
  "@quizPrivacyQ5A4": {
    "description": "quizPrivacyQ5A4"
  },
  "quizPrivacyQ5Explain": "Third-party tracking cookies follow you across thousands of websites, building a detailed profile: interests, purchases, location. Use 'do not track' mode and regularly clear cookies.",
  "@quizPrivacyQ5Explain": {
    "description": "quizPrivacyQ5Explain"
  },
  "quizLockQ4": "What keyboard shortcut instantly locks Windows?",
  "@quizLockQ4": {
    "description": "quizLockQ4"
  },
  "quizLockQ4A1": "Win + L - locks the screen instantly without closing programs",
  "@quizLockQ4A1": {
    "description": "quizLockQ4A1"
  },
  "quizLockQ4A2": "Ctrl + Alt + Delete - shuts down the computer",
  "@quizLockQ4A2": {
    "description": "quizLockQ4A2"
  },
  "quizLockQ4A3": "Alt + F4 - locks the current window",
  "@quizLockQ4A3": {
    "description": "quizLockQ4A3"
  },
  "quizLockQ4A4": "Ctrl + Z - pauses the computer",
  "@quizLockQ4A4": {
    "description": "quizLockQ4A4"
  },
  "quizLockQ4Explain": "Win + L is the fastest way to lock Windows. Building a habit of pressing Win + L every time you leave your seat protects against physical access. Programs continue running.",
  "@quizLockQ4Explain": {
    "description": "quizLockQ4Explain"
  },
  "quizLockQ5": "What is Dynamic Lock in Windows?",
  "@quizLockQ5": {
    "description": "quizLockQ5"
  },
  "quizLockQ5A1": "Automatic computer lock when your Bluetooth device (phone) moves out of range",
  "@quizLockQ5A1": {
    "description": "quizLockQ5A1"
  },
  "quizLockQ5A2": "Lock with a dynamically changing password",
  "@quizLockQ5A2": {
    "description": "quizLockQ5A2"
  },
  "quizLockQ5A3": "Protection against system file changes",
  "@quizLockQ5A3": {
    "description": "quizLockQ5A3"
  },
  "quizLockQ5A4": "A Windows antivirus feature",
  "@quizLockQ5A4": {
    "description": "quizLockQ5A4"
  },
  "quizLockQ5Explain": "Dynamic Lock pairs with your phone via Bluetooth. When you walk away and the phone goes out of range, Windows automatically locks the screen in about 30 seconds.",
  "@quizLockQ5Explain": {
    "description": "quizLockQ5Explain"
  },
  "quizExtQ4": "Why is checking browser extension permissions important?",
  "@quizExtQ4": {
    "description": "quizExtQ4"
  },
  "quizExtQ4A1": "An extension with 'access to all sites' can read your passwords and card data",
  "@quizExtQ4A1": {
    "description": "quizExtQ4A1"
  },
  "quizExtQ4A2": "Permissions affect browser speed",
  "@quizExtQ4A2": {
    "description": "quizExtQ4A2"
  },
  "quizExtQ4A3": "Without permissions the extension won't install",
  "@quizExtQ4A3": {
    "description": "quizExtQ4A3"
  },
  "quizExtQ4A4": "Permissions are only needed for paid extensions",
  "@quizExtQ4A4": {
    "description": "quizExtQ4A4"
  },
  "quizExtQ4Explain": "An extension with 'Read and change data on all sites' permission has full access to page content - including login forms, banking data, private messages. Grant minimum permissions.",
  "@quizExtQ4Explain": {
    "description": "quizExtQ4Explain"
  },
  "quizExtQ5": "How can you spot a fake browser extension?",
  "@quizExtQ5": {
    "description": "quizExtQ5"
  },
  "quizExtQ5A1": "Few reviews, no official website link, requests excessive permissions",
  "@quizExtQ5A1": {
    "description": "quizExtQ5A1"
  },
  "quizExtQ5A2": "It has an ugly icon",
  "@quizExtQ5A2": {
    "description": "quizExtQ5A2"
  },
  "quizExtQ5A3": "It's free - must be fake",
  "@quizExtQ5A3": {
    "description": "quizExtQ5A3"
  },
  "quizExtQ5A4": "There are no fake extensions in the Chrome Store",
  "@quizExtQ5A4": {
    "description": "quizExtQ5A4"
  },
  "quizExtQ5Explain": "Signs of a fake: few downloads and reviews, developer name mismatch, excessive permissions, recent publication date. Verify the developer on the official product website.",
  "@quizExtQ5Explain": {
    "description": "quizExtQ5Explain"
  },
  "quizEncryptQ4": "Why is BitLocker full-disk encryption needed?",
  "@quizEncryptQ4": {
    "description": "quizEncryptQ4"
  },
  "quizEncryptQ4A1": "Protects all disk data if the laptop is stolen or lost",
  "@quizEncryptQ4A1": {
    "description": "quizEncryptQ4A1"
  },
  "quizEncryptQ4A2": "Speeds up disk reads",
  "@quizEncryptQ4A2": {
    "description": "quizEncryptQ4A2"
  },
  "quizEncryptQ4A3": "Prevents virus infections",
  "@quizEncryptQ4A3": {
    "description": "quizEncryptQ4A3"
  },
  "quizEncryptQ4A4": "Only needed for servers",
  "@quizEncryptQ4A4": {
    "description": "quizEncryptQ4A4"
  },
  "quizEncryptQ4Explain": "Without BitLocker, removing the disk from a laptop and connecting it to another computer gives full access to all files. With BitLocker, data is encrypted and useless without the key tied to the TPM module.",
  "@quizEncryptQ4Explain": {
    "description": "quizEncryptQ4Explain"
  },
  "quizEncryptQ5": "What's the difference between HTTP and HTTPS?",
  "@quizEncryptQ5": {
    "description": "quizEncryptQ5"
  },
  "quizEncryptQ5A1": "HTTPS encrypts traffic between browser and server; HTTP transmits data in plain text",
  "@quizEncryptQ5A1": {
    "description": "quizEncryptQ5A1"
  },
  "quizEncryptQ5A2": "HTTPS is faster",
  "@quizEncryptQ5A2": {
    "description": "quizEncryptQ5A2"
  },
  "quizEncryptQ5A3": "HTTP is for computers, HTTPS is for phones",
  "@quizEncryptQ5A3": {
    "description": "quizEncryptQ5A3"
  },
  "quizEncryptQ5A4": "No difference - they're the same",
  "@quizEncryptQ5A4": {
    "description": "quizEncryptQ5A4"
  },
  "quizEncryptQ5Explain": "HTTPS uses TLS encryption: everything you send (passwords, card data) is encrypted. In HTTP, data is sent in plain text - anyone on the same network can intercept it. Never enter passwords on HTTP sites.",
  "@quizEncryptQ5Explain": {
    "description": "quizEncryptQ5Explain"
  },
